}

version() {
  echo "akvps $AKVPS_VERSION"
}

use_color() {
  [[ -t 1 && "${NO_COLOR:-}" == "" ]]
}

color_text() {
  local color="$1" text="$2" code=""
  if ! use_color; then
    printf "%s" "$text"
    return
  fi
  case "$color" in
    green) code="32" ;;
    yellow) code="33" ;;
    blue) code="34" ;;
    magenta) code="35" ;;
    cyan) code="36" ;;
    red) code="31" ;;
    *) code="0" ;;
  esac
  printf "\033[%sm%s\033[0m" "$code" "$text"
}

pause_menu() {
