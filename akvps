save_config_var() {
  local key="$1" value="$2"
  local escaped
  printf -v escaped "%q" "$value"
  touch "$AKVPS_CONFIG"
  if grep -q "^${key}=" "$AKVPS_CONFIG"; then
    sed -i.bak "s|^${key}=.*|${key}=${escaped}|" "$AKVPS_CONFIG"
  else
    printf "%s=%s\n" "$key" "$escaped" >> "$AKVPS_CONFIG"
  fi
  rm -f "$AKVPS_CONFIG.bak"
  chmod 600 "$AKVPS_CONFIG"
}

save_secret_var() {
  local key="$1" value="$2"
  local escaped
  printf -v escaped "%q" "$value"
  touch "$AKVPS_SECRETS"
  if grep -q "^${key}=" "$AKVPS_SECRETS"; then
    sed -i.bak "s|^${key}=.*|${key}=${escaped}|" "$AKVPS_SECRETS"
  else
    printf "%s=%s\n" "$key" "$escaped" >> "$AKVPS_SECRETS"
  fi
  rm -f "$AKVPS_SECRETS.bak"
  chmod 600 "$AKVPS_SECRETS"
}

save_state_var() {
  local key="$1" value="$2"
  local escaped
  printf -v escaped "%q" "$value"
  touch "$AKVPS_STATE"
  if grep -q "^${key}=" "$AKVPS_STATE"; then
    sed -i.bak "s|^${key}=.*|${key}=${escaped}|" "$AKVPS_STATE"
  else
    printf "%s=%s\n" "$key" "$escaped" >> "$AKVPS_STATE"
  fi
  rm -f "$AKVPS_STATE.bak"
  chmod 600 "$AKVPS_STATE"
}

valid_ipv4() {
  [[ "$1" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]
}

valid_ipv6() {
  [[ "$1" == *:* ]]
}

valid_domain() {
  [[ "$1" =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\.[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+$ ]]
}

mask_secret() {
  local value="$1"
  local len="${#value}"
  if [[ -z "$value" ]]; then
    echo "未设置"
  elif [[ "$len" -le 10 ]]; then
    echo "已设置"
  else
    echo "${value:0:6}...${value: -4}"
  fi
}

prompt_config() {
  info "读取基础配置"
  if [[ "$AKVPS_AUTO_DEPLOY" == "1" ]]; then
    [[ -n "$MASTER_IPV4" && "$MASTER_IPV4" != "未设置" && "$MASTER_IPV4" != "留空" ]] || die "缺少主控 IPv4。" "请在一键导入里填写 MASTER_IPV4。"
    valid_ipv4 "$MASTER_IPV4" || die "主控 IPv4 格式不正确：$MASTER_IPV4" "请检查一键导入里的 MASTER_IPV4。"
    prompt_cloudflare_token
    return
  fi
  while [[ -z "$MASTER_IPV4" ]] || ! valid_ipv4 "$MASTER_IPV4"; do
    read -r -p "请输入主控 IPv4: " MASTER_IPV4
  done
  save_config_var "MASTER_IPV4" "$MASTER_IPV4"
  read -r -p "请输入主控 IPv6（没有可直接回车）: " MASTER_IPV6_INPUT
  if [[ -n "$MASTER_IPV6_INPUT" ]]; then
    valid_ipv6 "$MASTER_IPV6_INPUT" || die "主控 IPv6 格式不正确。" "没有 IPv6 可以直接留空。"
    MASTER_IPV6="$MASTER_IPV6_INPUT"
    save_config_var "MASTER_IPV6" "$MASTER_IPV6"
  fi
  prompt_cloudflare_token
}

trim_value() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  value="${value%\"}"
  value="${value#\"}"
  value="${value%\'}"
  value="${value#\'}"
  printf "%s" "$value"
}

save_import_pair() {
  local key="$1" value="$2"
  key="$(trim_value "$key")"
  value="$(trim_value "$value")"
  [[ -n "$key" && -n "$value" ]] || return 0
  case "$key" in
    AKVPS_ROOT_DOMAIN|ROOT_DOMAIN)
      save_config_var "AKVPS_ROOT_DOMAIN" "$value"
      ;;
    MASTER_IPV4|MASTER_IP|MASTER)
      save_config_var "MASTER_IPV4" "$value"
      ;;
    MASTER_IPV6|MASTER_IPv6)
      save_config_var "MASTER_IPV6" "$value"
      ;;
    PANEL_DOMAIN|MASTER_PANEL_DOMAIN)
      save_config_var "PANEL_DOMAIN" "$value"
      ;;
    PANEL_URL|MASTER_PANEL_URL|XUI_PANEL_URL)
      save_config_var "PANEL_URL" "$value"
      ;;
    NODE_XUI_URL|NODE_URL)
      save_config_var "NODE_XUI_URL" "$value"
      ;;
    NODE_NAME|NODE)
      value="${value// /}"
      value="$(lower_text "$value")"
      save_config_var "NODE_NAME" "$value"
      ;;
    NODE_DOMAIN)
      save_config_var "NODE_DOMAIN" "$value"
      ;;
    NODE_PROTOCOLS|PROTOCOLS)
      save_config_var "NODE_PROTOCOLS" "$value"
      ;;
    LOCAL_DOWN_MBPS)
      save_config_var "LOCAL_DOWN_MBPS" "$value"
      ;;
    LOCAL_UP_MBPS)
      save_config_var "LOCAL_UP_MBPS" "$value"
      ;;
    VPS_MBPS)
      save_config_var "VPS_MBPS" "$value"
      ;;
    RTT_MS|PING_MS)
      save_config_var "RTT_MS" "$value"
      ;;
    LINE_QUALITY)
      save_config_var "LINE_QUALITY" "$value"
      ;;
    KOMARI_MONTH_ROTATE|MONTH_ROTATE)
      save_config_var "KOMARI_MONTH_ROTATE" "$value"
      ;;
    KOMARI_SERVER_DOMAIN)
      save_config_var "KOMARI_SERVER_DOMAIN" "$value"
      ;;
    KOMARI_ENDPOINT|KOMARI_URL|KOMARI_SERVER_URL)
      save_config_var "KOMARI_ENDPOINT" "$value"
      ;;
    KOMARI_AUTO_DISCOVERY_KEY|KOMARI_DISCOVERY_KEY|AUTO_DISCOVERY_KEY)
      save_secret_var "KOMARI_AUTO_DISCOVERY_KEY" "$value"
      ;;
    CLOUDFLARE_TOKEN|CF_TOKEN)
      save_secret_var "CLOUDFLARE_TOKEN" "$value"
      ;;
    PANEL_API_TOKEN|XUI_API_TOKEN|MASTER_PANEL_API_TOKEN)
      save_secret_var "PANEL_API_TOKEN" "$value"
      ;;
    NODE_XUI_API_TOKEN|NODE_API_TOKEN)
      save_secret_var "NODE_XUI_API_TOKEN" "$value"
      ;;
    *)
      echo "已跳过未知字段：$key"
      ;;
  esac
}

paste_import_lines() {
  local title="$1"
  local count=0
  info "$title"
  echo "请粘贴配置，格式：KEY=VALUE"
  echo "粘贴完成后，单独输入 END 结束。"
  while IFS= read -r line; do
    [[ "$line" == "END" ]] && break
    [[ -z "${line// /}" || "$line" == \#* ]] && continue
    if [[ "$line" == *"="* ]]; then
      save_import_pair "${line%%=*}" "${line#*=}"
      count=$((count + 1))
    else
      echo "已跳过格式不正确的一行。"
    fi
  done
  if [[ "$count" -eq 0 ]]; then
    echo "没有导入任何内容。"
  else
    echo "已导入 ${count} 项。敏感信息不会在这里显示。"
  fi
}

