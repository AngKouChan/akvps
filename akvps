#!/usr/bin/env bash
set -Eeuo pipefail

AKVPS_VERSION="0.1.4-mvp"
AKVPS_DIR="/etc/akvps"
AKVPS_CONFIG="$AKVPS_DIR/config.env"
AKVPS_SECRETS="$AKVPS_DIR/secrets.env"
AKVPS_STATE="/var/lib/akvps/state.env"
AKVPS_REPORT_DIR="/var/lib/akvps/reports"
AKVPS_LATEST_REPORT="/var/lib/akvps/latest-report.md"
AKVPS_LATEST_PANEL_REPORT="/var/lib/akvps/latest-panel-report.md"
AKVPS_LATEST_KOMARI_REPORT="/var/lib/akvps/latest-komari-report.md"
AKVPS_LATEST_KOMARI_SERVER_REPORT="/var/lib/akvps/latest-komari-server-report.md"
AKVPS_SYSCTL="/etc/sysctl.d/99-akvps.conf"
AKVPS_SSHD_CONF="/etc/ssh/sshd_config.d/99-akvps-key-only.conf"
AKVPS_ROOT_DOMAIN="kouzho.cc"
AKVPS_XUI_PORT="11123"
AKVPS_PANEL_PORT="11123"
AKVPS_KOMARI_PORT="25774"
AKVPS_VLESS_PORT="11789"
AKVPS_HY2_PORT="11799"
AKVPS_HY2_HOP_START="39999"
AKVPS_HY2_HOP_END="59999"
AKVPS_TERMIUS_PUBKEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIG1hH9mQn8JLkMbbstN+ZHGAQIcTR6zN2wUxWdkIBxYt Generated By Termius"
XUI_BIN="/usr/local/x-ui/x-ui"
XUI_RESULT="/etc/x-ui/install-result.env"
XUI_DB="/etc/x-ui/x-ui.db"

MASTER_IPV4=""
CLOUDFLARE_TOKEN=""
NODE_NAME=""
NODE_DOMAIN=""
PANEL_NAME=""
PANEL_DOMAIN=""
KOMARI_ENDPOINT=""
KOMARI_TOKEN=""
KOMARI_SERVER_NAME=""
KOMARI_SERVER_DOMAIN=""
PUBLIC_IPV4=""
PUBLIC_IPV6=""
SELECT_VLESS=0
SELECT_HY2=0
SELECT_HY2_HOP=0
TUNING_MODE="smart"
LOCAL_DOWN_MBPS="1000"
LOCAL_UP_MBPS="50"
VPS_MBPS="1000"
RTT_MS=""
LINE_QUALITY="1"
REPORT_PATH=""
XUI_USERNAME=""
XUI_PASSWORD=""
XUI_WEB_BASE_PATH=""
XUI_API_TOKEN=""
XUI_ACCESS_URL=""
PANEL_REPORT_PATH=""
KOMARI_REPORT_PATH=""
KOMARI_SERVER_REPORT_PATH=""

die() {
  echo
  echo "失败：$1"
  [[ $# -gt 1 ]] && echo "建议：$2"
  exit 1
}

info() {
  echo
  echo "== $1 =="
}

version() {
  echo "akvps $AKVPS_VERSION"
}

need_root() {
  [[ "${EUID:-$(id -u)}" -eq 0 ]] || die "需要 root 权限。" "请用 root 登录 VPS 后再运行 akvps。"
}

ensure_dirs() {
  install -d -m 700 "$AKVPS_DIR"
  install -d -m 700 "$(dirname "$AKVPS_STATE")"
  install -d -m 700 "$AKVPS_REPORT_DIR"
  touch "$AKVPS_CONFIG" "$AKVPS_SECRETS" "$AKVPS_STATE"
  chmod 600 "$AKVPS_CONFIG" "$AKVPS_SECRETS" "$AKVPS_STATE"
}

load_envs() {
  [[ -f "$AKVPS_CONFIG" ]] && source "$AKVPS_CONFIG" || true
  [[ -f "$AKVPS_SECRETS" ]] && source "$AKVPS_SECRETS" || true
  MASTER_IPV4="${MASTER_IPV4:-}"
  CLOUDFLARE_TOKEN="${CLOUDFLARE_TOKEN:-}"
  KOMARI_ENDPOINT="${KOMARI_ENDPOINT:-}"
  KOMARI_TOKEN="${KOMARI_TOKEN:-}"
}

save_config_var() {
  local key="$1" value="$2"
  local escaped
  printf -v escaped "%q" "$value"
  touch "$AKVPS_CONFIG"
  if grep -q "^${key}=" "$AKVPS_CONFIG"; then
    sed -i.bak "s|^${key}=.*|${key}=${escaped}|" "$AKVPS_CONFIG"
  else
    printf "%s=%s\n" "$key" "$escaped" >> "$AKVPS_CONFIG"
  fi
  rm -f "$AKVPS_CONFIG.bak"
  chmod 600 "$AKVPS_CONFIG"
}

save_secret_var() {
  local key="$1" value="$2"
  local escaped
  printf -v escaped "%q" "$value"
  touch "$AKVPS_SECRETS"
  if grep -q "^${key}=" "$AKVPS_SECRETS"; then
    sed -i.bak "s|^${key}=.*|${key}=${escaped}|" "$AKVPS_SECRETS"
  else
    printf "%s=%s\n" "$key" "$escaped" >> "$AKVPS_SECRETS"
  fi
  rm -f "$AKVPS_SECRETS.bak"
  chmod 600 "$AKVPS_SECRETS"
}

valid_ipv4() {
  [[ "$1" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]]
}

valid_domain() {
  [[ "$1" =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\.[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+$ ]]
}

prompt_config() {
  info "读取基础配置"
  while [[ -z "$MASTER_IPV4" ]] || ! valid_ipv4 "$MASTER_IPV4"; do
    read -r -p "请输入主控 IPv4: " MASTER_IPV4
  done
  save_config_var "MASTER_IPV4" "$MASTER_IPV4"
  prompt_cloudflare_token
}

prompt_cloudflare_token() {
  if [[ -n "$CLOUDFLARE_TOKEN" ]] && cloudflare_token_ok; then
    echo "Cloudflare Token 可用。"
    return
  fi
  while true; do
    read -r -s -p "请输入 Cloudflare Token: " CLOUDFLARE_TOKEN
    echo
    [[ -n "$CLOUDFLARE_TOKEN" ]] || continue
    if cloudflare_token_ok; then
      save_secret_var "CLOUDFLARE_TOKEN" "$CLOUDFLARE_TOKEN"
      break
    fi
    echo "Cloudflare Token 不可用，请重新输入。"
  done
}

cloudflare_api() {
  local method="$1" url="$2" data="${3:-}"
  if [[ -n "$data" ]]; then
    curl -fsS -X "$method" "https://api.cloudflare.com/client/v4/$url" \
      -H "Authorization: Bearer $CLOUDFLARE_TOKEN" \
      -H "Content-Type: application/json" \
      --data "$data"
  else
    curl -fsS -X "$method" "https://api.cloudflare.com/client/v4/$url" \
      -H "Authorization: Bearer $CLOUDFLARE_TOKEN" \
      -H "Content-Type: application/json"
  fi
}

cloudflare_token_ok() {
  [[ -n "$CLOUDFLARE_TOKEN" ]] || return 1
  cloudflare_api GET "zones?name=$AKVPS_ROOT_DOMAIN" >/dev/null 2>&1
}

require_tools_for_json() {
  command -v jq >/dev/null 2>&1 || die "缺少 jq。" "请先让 akvps 安装必要工具，或手动安装 jq。"
}

check_system() {
  info "系统体检"
  [[ -f /etc/os-release ]] || die "无法识别系统。" "第一版只支持 Debian / Ubuntu。"
  # shellcheck disable=SC1091
  source /etc/os-release
  local ok=0
  case "${ID}:${VERSION_ID}" in
    debian:11|debian:12|debian:13|ubuntu:22.04|ubuntu:24.04) ok=1 ;;
  esac
  [[ "$ok" -eq 1 ]] || die "不支持当前系统：${PRETTY_NAME:-unknown}" "请使用 Debian 11/12/13 或 Ubuntu 22.04/24.04。"
  command -v ss >/dev/null 2>&1 || true
  echo "系统：${PRETTY_NAME:-unknown}"
}

detect_public_ips() {
  PUBLIC_IPV4="$(curl -4 -fsS --max-time 5 https://api4.ipify.org 2>/dev/null || true)"
  PUBLIC_IPV6="$(curl -6 -fsS --max-time 5 https://api6.ipify.org 2>/dev/null || true)"
  [[ -n "$PUBLIC_IPV4" ]] || die "没有检测到公网 IPv4。" "请检查 VPS 网络。"
  echo "IPv4：$PUBLIC_IPV4"
  [[ -n "$PUBLIC_IPV6" ]] && echo "IPv6：$PUBLIC_IPV6" || echo "IPv6：无"
}

port_in_use() {
  local port="$1" proto="${2:-tcp}"
  ss -lntu 2>/dev/null | awk -v p=":${port}$" -v proto="$proto" 'tolower($1) ~ proto && $5 ~ p {found=1} END{exit found?0:1}'
}

check_ports() {
  local ports=("$AKVPS_XUI_PORT")
  [[ "$SELECT_VLESS" -eq 1 ]] && ports+=("$AKVPS_VLESS_PORT")
  [[ "$SELECT_HY2" -eq 1 ]] && ports+=("$AKVPS_HY2_PORT")
  for p in "${ports[@]}"; do
    if port_in_use "$p"; then
      [[ "$p" == "$AKVPS_XUI_PORT" && -x "$XUI_BIN" ]] && continue
      die "端口 $p 已被占用。" "请先释放端口，再重新运行 akvps。"
    fi
  done
}

prompt_node() {
  info "节点信息"
  while true; do
    read -r -p "请输入节点短名，例如 jp1: " NODE_NAME
    NODE_NAME="${NODE_NAME// /}"
    NODE_DOMAIN="${NODE_NAME}.${AKVPS_ROOT_DOMAIN}"
    valid_domain "$NODE_DOMAIN" && break
    echo "节点短名无法组成合法域名，请重新输入。"
  done
  echo "节点域名：$NODE_DOMAIN"
}

prompt_protocols() {
  info "协议准备"
  echo "可多选，例如 1 2"
  echo "1. VLESS Reality"
  echo "2. Hysteria2"
  echo "3. Hysteria2 + 端口跳跃"
  while true; do
    read -r -p "请选择协议: " choices
    SELECT_VLESS=0
    SELECT_HY2=0
    SELECT_HY2_HOP=0
    for c in $choices; do
      case "$c" in
        1) SELECT_VLESS=1 ;;
        2) SELECT_HY2=1 ;;
        3) SELECT_HY2=1; SELECT_HY2_HOP=1 ;;
      esac
    done
    [[ "$SELECT_VLESS" -eq 1 || "$SELECT_HY2" -eq 1 ]] && break
    echo "至少选择一个协议。"
  done
}

install_base_tools() {
  info "安装必要工具"
  apt-get update
  DEBIAN_FRONTEND=noninteractive apt-get install -y -q curl ca-certificates ufw jq unzip tar cron openssl sqlite3 iproute2 libc-bin
  timedatectl set-timezone Asia/Shanghai || true
}

install_light_tools() {
  info "安装必要工具"
  apt-get update
  DEBIAN_FRONTEND=noninteractive apt-get install -y -q curl ca-certificates
  timedatectl set-timezone Asia/Shanghai || true
}

setup_ssh() {
  info "配置 SSH 密钥登录"
  install -d -m 700 /root/.ssh
  touch /root/.ssh/authorized_keys
  chmod 600 /root/.ssh/authorized_keys
  grep -qxF "$AKVPS_TERMIUS_PUBKEY" /root/.ssh/authorized_keys || printf "%s\n" "$AKVPS_TERMIUS_PUBKEY" >> /root/.ssh/authorized_keys

  install -d -m 755 /etc/ssh/sshd_config.d
  [[ -f /etc/ssh/sshd_config ]] && cp -a /etc/ssh/sshd_config "/etc/ssh/sshd_config.bak.akvps.$(date +%F-%H%M%S)" || true
  cat > "$AKVPS_SSHD_CONF" <<'EOF'
PubkeyAuthentication yes
PasswordAuthentication no
KbdInteractiveAuthentication no
PermitRootLogin prohibit-password
EOF
  if ! sshd -t; then
    rm -f "$AKVPS_SSHD_CONF"
    die "SSH 配置检查失败，已回滚。" "请检查系统 SSH 配置后重试。"
  fi
  systemctl reload ssh 2>/dev/null || systemctl reload sshd 2>/dev/null || true
}

restore_ssh_password() {
  need_root
  rm -f "$AKVPS_SSHD_CONF"
  systemctl reload ssh 2>/dev/null || systemctl reload sshd 2>/dev/null || true
  echo "已恢复 SSH 密码登录配置。"
}

setup_swap() {
  info "检查 Swap"
  if swapon --show | grep -q .; then
    echo "已有 Swap，跳过。"
    return
  fi
  local mem_kb mem_mb
  mem_kb="$(awk '/MemTotal/ {print $2}' /proc/meminfo)"
  mem_mb=$((mem_kb / 1024))
  if (( mem_mb > 4096 )); then
    echo "内存大于 4G，默认不创建 Swap。"
    return
  fi
  read -r -p "建议创建 1G Swap，是否创建？[Y/n] " ans
  ans="${ans:-Y}"
  [[ "$ans" =~ ^[Yy]$ ]] || return
  fallocate -l 1G /swapfile || dd if=/dev/zero of=/swapfile bs=1M count=1024
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  grep -q '^/swapfile ' /etc/fstab || echo '/swapfile none swap sw 0 0' >> /etc/fstab
}

prompt_tuning() {
  info "调优选择"
  read -r -p "是否启用智能调优？[Y/n] " ans
  ans="${ans:-Y}"
  if [[ "$ans" =~ ^[Nn]$ ]]; then
    TUNING_MODE="basic"
    return
  fi
  TUNING_MODE="smart"
  read -r -p "本地下载 Mbps [1000]: " v
  LOCAL_DOWN_MBPS="${v:-1000}"
  read -r -p "本地上传 Mbps [50]: " v
  LOCAL_UP_MBPS="${v:-50}"
  read -r -p "VPS 标称 Mbps [1000]: " v
  VPS_MBPS="${v:-1000}"
  while [[ -z "$RTT_MS" ]]; do
    read -r -p "本地到 VPS 平均 ping 延迟 ms（必填，可填大概值）: " RTT_MS
  done
  echo "线路质量："
  echo "1. 稳定"
  echo "2. 波动"
  echo "3. 丢包明显"
  read -r -p "请选择 [1]: " LINE_QUALITY
  LINE_QUALITY="${LINE_QUALITY:-1}"
}

apply_tuning() {
  info "应用系统调优"
  [[ -f "$AKVPS_SYSCTL" ]] && cp -a "$AKVPS_SYSCTL" "$AKVPS_SYSCTL.bak.$(date +%F-%H%M%S)"
  local mem_kb mem_mb tcp_mem udp_mem rmem_max wmem_max
  mem_kb="$(awk '/MemTotal/ {print $2}' /proc/meminfo)"
  mem_mb=$((mem_kb / 1024))
  rmem_max=67108864
  wmem_max=67108864
  if [[ "$TUNING_MODE" == "smart" ]]; then
    if (( VPS_MBPS >= 1000 && RTT_MS >= 150 )); then
      rmem_max=134217728
      wmem_max=134217728
    fi
    if [[ "$LINE_QUALITY" == "3" ]]; then
      rmem_max=67108864
      wmem_max=67108864
    fi
  fi
  tcp_mem="786432 1048576 1572864"
  udp_mem="262144 524288 1048576"
  if (( mem_mb < 1024 )); then
    tcp_mem="196608 262144 393216"
    udp_mem="65536 131072 262144"
    rmem_max=33554432
    wmem_max=33554432
  fi
  cat > "$AKVPS_SYSCTL" <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
net.core.rmem_max=$rmem_max
net.core.wmem_max=$wmem_max
net.ipv4.tcp_rmem=4096 87380 $rmem_max
net.ipv4.tcp_wmem=4096 65536 $wmem_max
net.ipv4.tcp_mtu_probing=1
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_mem=$tcp_mem
net.ipv4.udp_mem=$udp_mem
net.core.somaxconn=4096
net.ipv4.ip_local_port_range=1024 65535
EOF
  sysctl --system >/dev/null
  sysctl net.ipv4.tcp_congestion_control net.core.default_qdisc
}

setup_ufw() {
  info "配置 UFW"
  local ssh_port
  ssh_port="$(sshd -T 2>/dev/null | awk '/^port / {print $2; exit}')"
  ssh_port="${ssh_port:-22}"
  ufw --force reset
  ufw default deny incoming
  ufw default allow outgoing
  ufw allow "$ssh_port/tcp" comment "ssh"
  ufw allow 80/tcp comment "acme"
  ufw allow 443/tcp comment "https"
  ufw allow from "$MASTER_IPV4" to any port "$AKVPS_XUI_PORT" proto tcp comment "akvps x-ui master"
  [[ "$SELECT_VLESS" -eq 1 ]] && ufw allow "$AKVPS_VLESS_PORT/tcp" comment "vless reality"
  [[ "$SELECT_HY2" -eq 1 ]] && ufw allow "$AKVPS_HY2_PORT/udp" comment "hysteria2"
  [[ "$SELECT_HY2_HOP" -eq 1 ]] && ufw allow "$AKVPS_HY2_HOP_START:$AKVPS_HY2_HOP_END/udp" comment "hysteria2 hop"
  ufw --force enable
  ufw reload
}

setup_panel_ufw() {
  info "配置 UFW"
  local ssh_port
  ssh_port="$(sshd -T 2>/dev/null | awk '/^port / {print $2; exit}')"
  ssh_port="${ssh_port:-22}"
  ufw --force reset
  ufw default deny incoming
  ufw default allow outgoing
  ufw allow "$ssh_port/tcp" comment "ssh"
  ufw allow 80/tcp comment "acme"
  ufw allow 443/tcp comment "https"
  ufw allow "$AKVPS_PANEL_PORT/tcp" comment "3x-ui panel"
  ufw --force enable
  ufw reload
}

setup_komari_server_ufw() {
  info "配置 UFW"
  local ssh_port
  ssh_port="$(sshd -T 2>/dev/null | awk '/^port / {print $2; exit}')"
  ssh_port="${ssh_port:-22}"
  ufw --force reset
  ufw default deny incoming
  ufw default allow outgoing
  ufw allow "$ssh_port/tcp" comment "ssh"
  ufw allow "$AKVPS_KOMARI_PORT/tcp" comment "komari server"
  ufw --force enable
  ufw reload
}

cf_zone_id() {
  require_tools_for_json
  cloudflare_api GET "zones?name=$AKVPS_ROOT_DOMAIN" | jq -r '.result[0].id // empty'
}

upsert_dns_record() {
  local zone_id="$1" type="$2" name="$3" content="$4"
  [[ -n "$content" ]] || return 0
  local record_id payload
  record_id="$(cloudflare_api GET "zones/$zone_id/dns_records?type=$type&name=$name" | jq -r '.result[0].id // empty')"
  payload="$(jq -n --arg type "$type" --arg name "$name" --arg content "$content" '{type:$type,name:$name,content:$content,ttl:1,proxied:false}')"
  if [[ -n "$record_id" ]]; then
    cloudflare_api PUT "zones/$zone_id/dns_records/$record_id" "$payload" >/dev/null
  else
    cloudflare_api POST "zones/$zone_id/dns_records" "$payload" >/dev/null
  fi
}

setup_dns() {
  info "配置 Cloudflare DNS"
  local zone_id
  zone_id="$(cf_zone_id)"
  [[ -n "$zone_id" ]] || die "找不到 Cloudflare Zone：$AKVPS_ROOT_DOMAIN" "请检查 Token 权限是否包含 Zone Read 和 DNS Edit。"
  upsert_dns_record "$zone_id" "A" "$NODE_DOMAIN" "$PUBLIC_IPV4"
  [[ -n "$PUBLIC_IPV6" ]] && upsert_dns_record "$zone_id" "AAAA" "$NODE_DOMAIN" "$PUBLIC_IPV6"
  echo "DNS 已更新：$NODE_DOMAIN"
}

setup_dns_for_domain() {
  local domain="$1"
  info "配置 Cloudflare DNS"
  local zone_id
  zone_id="$(cf_zone_id)"
  [[ -n "$zone_id" ]] || die "找不到 Cloudflare Zone：$AKVPS_ROOT_DOMAIN" "请检查 Token 权限是否包含 Zone Read 和 DNS Edit。"
  upsert_dns_record "$zone_id" "A" "$domain" "$PUBLIC_IPV4"
  [[ -n "$PUBLIC_IPV6" ]] && upsert_dns_record "$zone_id" "AAAA" "$domain" "$PUBLIC_IPV6"
  echo "DNS 已更新：$domain"
}

wait_dns() {
  info "等待 DNS 生效"
  wait_dns_for_domain "$NODE_DOMAIN"
}

wait_dns_for_domain() {
  local domain="$1"
  local i resolved=""
  for i in $(seq 1 30); do
    resolved="$(getent ahostsv4 "$domain" 2>/dev/null | awk '{print $1}' | sort -u | tr '\n' ' ' || true)"
    if [[ " $resolved " == *" $PUBLIC_IPV4 "* ]]; then
      echo "DNS 已生效：$domain -> $PUBLIC_IPV4"
      return 0
    fi
    echo "等待 DNS 生效中... $i/30"
    sleep 10
  done
  die "DNS 暂未解析到当前 VPS IPv4。" "请稍后重新运行 akvps，或检查 Cloudflare DNS。"
}

random_string() {
  openssl rand -hex 64 | cut -c "1-${1:-18}"
}

delete_old_api_tokens() {
  [[ -f "$XUI_DB" ]] || return 0
  systemctl stop x-ui 2>/dev/null || true
  sqlite3 "$XUI_DB" "delete from api_tokens;" >/dev/null 2>&1 || true
}

install_or_configure_xui() {
  info "安装/配置 3x-ui 远端节点端"
  XUI_USERNAME="ak$(random_string 8)"
  XUI_PASSWORD="$(random_string 18)"
  XUI_WEB_BASE_PATH="$(random_string 18)"
  export XUI_NONINTERACTIVE=1
  export XUI_PANEL_PORT="$AKVPS_XUI_PORT"
  export XUI_DOMAIN="$NODE_DOMAIN"
  export XUI_SSL_MODE="domain"
  export XUI_WEB_BASE_PATH="$XUI_WEB_BASE_PATH"
  export XUI_USERNAME="$XUI_USERNAME"
  export XUI_PASSWORD="$XUI_PASSWORD"
  export XUI_DB_TYPE="sqlite"
  export XUI_SERVER_IP="$PUBLIC_IPV4"
  bash <(curl -fsSL https://raw.githubusercontent.com/MHSanaei/3x-ui/master/install.sh)

  [[ -x "$XUI_BIN" ]] || die "3x-ui 安装后未找到 x-ui 命令。" "请检查官方安装脚本输出。"
  "$XUI_BIN" setting -username "$XUI_USERNAME" -password "$XUI_PASSWORD" -port "$AKVPS_XUI_PORT" -webBasePath "$XUI_WEB_BASE_PATH"
  delete_old_api_tokens
  XUI_API_TOKEN="$("$XUI_BIN" setting -getApiToken true 2>/dev/null | awk '/apiToken:/ {print $2; exit}')"
  [[ -n "$XUI_API_TOKEN" ]] || die "未能生成 3x-ui API Token。" "请检查 3x-ui 是否正常运行。"
  systemctl restart x-ui 2>/dev/null || true
  XUI_ACCESS_URL="https://${NODE_DOMAIN}:${AKVPS_XUI_PORT}/${XUI_WEB_BASE_PATH}"
  curl -kfsS --max-time 10 "https://127.0.0.1:${AKVPS_XUI_PORT}/${XUI_WEB_BASE_PATH}" >/dev/null 2>&1 || true
}

