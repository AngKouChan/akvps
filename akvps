prompt_komari() {
  info "Komari 探针信息"
  if [[ -n "$KOMARI_ENDPOINT" ]]; then
    echo "Komari 主站地址：$KOMARI_ENDPOINT"
  else
    while true; do
      read -r -p "请输入 Komari 主站地址，例如 https://status.kouzho.cc: " KOMARI_ENDPOINT
      KOMARI_ENDPOINT="${KOMARI_ENDPOINT%/}"
      [[ "$KOMARI_ENDPOINT" =~ ^https?://[^[:space:]]+$ ]] && break
      echo "地址格式不正确，请以 http:// 或 https:// 开头。"
    done
  fi
  save_config_var "KOMARI_ENDPOINT" "$KOMARI_ENDPOINT"
  if [[ -n "$KOMARI_MONTH_ROTATE" ]]; then
    [[ "$KOMARI_MONTH_ROTATE" =~ ^([0-9]|[12][0-9]|3[01])$ ]] || die "网络统计月重置日格式不正确。" "请填写 0 到 31。"
    echo "网络统计月重置日：$KOMARI_MONTH_ROTATE"
  else
    while true; do
      read -r -p "请输入网络统计月重置日，0=禁用，1-31=每月日期: " KOMARI_MONTH_ROTATE
      if [[ "$KOMARI_MONTH_ROTATE" =~ ^([0-9]|[12][0-9]|3[01])$ ]]; then
        break
      fi
      echo "请输入 0 到 31 之间的数字。"
    done
  fi
  save_config_var "KOMARI_MONTH_ROTATE" "$KOMARI_MONTH_ROTATE"
  if [[ -n "$KOMARI_AUTO_DISCOVERY_KEY" ]]; then
    echo "已使用 Komari 自动发现密钥，将自动注册本机。"
    return
  fi
  if [[ "$AKVPS_AUTO_DEPLOY" == "1" ]]; then
    die "缺少 Komari 自动发现密钥。" "请在一键导入里填写 KOMARI_AUTO_DISCOVERY_KEY。"
  fi
  echo "未配置 Komari 自动发现密钥，将使用手动 Token 方式。"
  while [[ -z "$KOMARI_TOKEN" ]]; do
    read -r -s -p "请输入 Komari 节点 Token: " KOMARI_TOKEN
    echo
  done
  save_secret_var "KOMARI_TOKEN" "$KOMARI_TOKEN"
}

