}

download_latest_akvps() {
  local dest="$1" latest_sha source_url downloaded_version cachebust
  latest_sha="$(curl -fsSL --connect-timeout 10 --max-time 30 https://api.github.com/repos/AngKouChan/akvps/commits/main 2>/dev/null \
    | sed -n 's/^[[:space:]]*"sha": *"\([0-9a-f]\{40\}\)".*/\1/p' \
    | head -n1 || true)"
  source_url="https://raw.githubusercontent.com/AngKouChan/akvps/${latest_sha:-main}/akvps"
  cachebust="$(date +%s)"
  curl -fsSL --connect-timeout 10 --max-time 60 -H "Cache-Control: no-cache" "${source_url}?cachebust=${cachebust}" -o "$dest" \
    || die "下载新版 akvps 失败。" "请检查 VPS 能否访问 GitHub raw.githubusercontent.com。"
  downloaded_version="$(sed -n 's/^AKVPS_VERSION="\([^"]*\)".*/\1/p' "$dest" | head -n1)"
  [[ -n "$downloaded_version" ]] || die "下载到的文件不是有效 akvps 脚本。" "请稍后重试，或用固定提交安装命令。"
  grep -q '^main_menu()' "$dest" || die "下载到的 akvps 脚本不完整。" "请稍后重试，或用固定提交安装命令。"
  printf "%s\n" "$downloaded_version"
}

use_color() {
  [[ -t 1 && "${NO_COLOR:-}" == "" ]]
}

color_text() {
  local color="$1" text="$2" code=""
  if ! use_color; then
    printf "%s" "$text"
    return
  fi
  case "$color" in
    green) code="32" ;;
    yellow) code="33" ;;
    blue) code="34" ;;
    magenta) code="35" ;;
    cyan) code="36" ;;
    red) code="31" ;;
    *) code="0" ;;
  esac
  printf "\033[%sm%s\033[0m" "$code" "$text"
}

lower_text() {
  printf "%s" "$1" | tr '[:upper:]' '[:lower:]'
}

url_encode() {
