  PANEL_REPORT_PATH="$AKVPS_REPORT_DIR/$(date +%F-%H%M%S)-panel-${PANEL_NAME}.md"
  local status_xui status_ufw status_dns
  status_xui="$(systemctl is-active x-ui 2>/dev/null || echo unknown)"
  status_ufw="$(ufw status 2>/dev/null | head -n1 || echo unknown)"
  status_dns="A=$PUBLIC_IPV4"
  [[ -n "$PUBLIC_IPV6" ]] && status_dns="$status_dns AAAA=$PUBLIC_IPV6"
  cat > "$PANEL_REPORT_PATH" <<EOF
# akvps 主控面板卡片

## 一、登录信息

| 项目 | 内容 |
|---|---|
| 主控名称 | ${PANEL_NAME} |
| 主控域名 | ${PANEL_DOMAIN} |
| 面板地址 | ${XUI_ACCESS_URL} |
