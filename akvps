  REPORT_PATH="$AKVPS_REPORT_DIR/$(date +%F-%H%M%S)-${NODE_NAME}.md"
  local status_xui status_ufw status_dns status_ssh bbr qdisc proto_lines connect_block
  status_xui="$(systemctl is-active x-ui 2>/dev/null || echo unknown)"
  status_ufw="$(ufw status 2>/dev/null | head -n1 || echo unknown)"
  status_dns="A=$PUBLIC_IPV4"
  [[ -n "$PUBLIC_IPV6" ]] && status_dns="$status_dns AAAA=$PUBLIC_IPV6"
  status_ssh="Termius 公钥已写入；密码登录已禁用"
  bbr="$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo unknown)"
  qdisc="$(sysctl -n net.core.default_qdisc 2>/dev/null || echo unknown)"
  proto_lines=""
  [[ "$SELECT_VLESS" -eq 1 ]] && proto_lines+=$'\n'"- VLESS Reality：端口 ${AKVPS_VLESS_PORT}/tcp"
  [[ "$SELECT_HY2" -eq 1 ]] && proto_lines+=$'\n'"- Hysteria2：端口 ${AKVPS_HY2_PORT}/udp"
  [[ "$SELECT_HY2_HOP" -eq 1 ]] && proto_lines+=$'\n'"- Hysteria2 端口跳跃：${AKVPS_HY2_HOP_START}-${AKVPS_HY2_HOP_END}/udp"
