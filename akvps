install_komari_server() {
  info "安装 Komari 主站"
  KOMARI_SERVER_REUSED=0
  if port_in_use "$AKVPS_KOMARI_PORT"; then
    if systemctl is-active --quiet komari 2>/dev/null; then
      echo "检测到已安装 Komari 主站。"
      echo "1. 复用现有主站"
      echo "2. 重装主站（会删除旧 Komari 数据，并重新生成账号密码）"
      echo "0. 取消"
      read -r -p "请选择: " choice
      case "$choice" in
        1)
          KOMARI_SERVER_REUSED=1
          return 0
          ;;
        2)
          read -r -p "确认重装？输入 YES 继续: " confirm
          [[ "$confirm" == "YES" ]] || die "已取消重装。" "需要时重新运行探针主站部署。"
          systemctl stop komari 2>/dev/null || true
          systemctl disable komari 2>/dev/null || true
          rm -f "$KOMARI_SERVICE"
          systemctl daemon-reload 2>/dev/null || true
          rm -rf "$KOMARI_DIR"
          ;;
        0)
          die "已取消。" "需要时重新运行探针主站部署。"
          ;;
        *)
          die "选择无效。" "请选择 1、2 或 0。"
          ;;
      esac
    else
      die "端口 $AKVPS_KOMARI_PORT 已被占用。" "请先释放端口，再重新运行 akvps。"
    fi
  fi
  tmp_file="$(mktemp)"
  curl -fsSL https://raw.githubusercontent.com/komari-monitor/komari/main/install-komari.sh -o "$tmp_file"
  chmod +x "$tmp_file"
  printf "1\n\n" | "$tmp_file"
  rm -f "$tmp_file"
  systemctl is-active --quiet komari 2>/dev/null || die "Komari 主站安装后未运行。" "请查看 journalctl -u komari -n 80。"
}

setup_komari_caddy() {
  info "配置 Komari HTTPS"
  local i
  mkdir -p /etc/caddy
  cat > /etc/caddy/Caddyfile <<EOF
${KOMARI_SERVER_DOMAIN} {
  reverse_proxy 127.0.0.1:${AKVPS_KOMARI_PORT}
}
EOF
  caddy validate --config /etc/caddy/Caddyfile >/dev/null
  systemctl enable caddy >/dev/null 2>&1 || true
  systemctl restart caddy
  for i in $(seq 1 24); do
    if curl -fsS --max-time 10 "https://${KOMARI_SERVER_DOMAIN}" >/dev/null 2>&1; then
      echo "Komari HTTPS 已生效：https://${KOMARI_SERVER_DOMAIN}"
      return 0
    fi
    echo "等待 HTTPS 生效中... $i/24"
    sleep 5
  done
  die "Komari HTTPS 暂未成功。" "请稍后访问 https://${KOMARI_SERVER_DOMAIN}，或查看 journalctl -u caddy -n 80。"
}

