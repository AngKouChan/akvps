  export XUI_DB_TYPE="sqlite"
  export XUI_SERVER_IP="$PUBLIC_IPV4"
  bash <(curl -fsSL https://raw.githubusercontent.com/MHSanaei/3x-ui/master/install.sh)

  [[ -x "$XUI_BIN" ]] || die "3x-ui 安装后未找到 x-ui 命令。" "请检查官方安装脚本输出。"
  "$XUI_BIN" setting -username "$XUI_USERNAME" -password "$XUI_PASSWORD" -port "$AKVPS_PANEL_PORT" -webBasePath "$XUI_WEB_BASE_PATH"
  delete_old_api_tokens
  XUI_API_TOKEN="$("$XUI_BIN" setting -getApiToken true 2>/dev/null | awk '/apiToken:/ {print $2; exit}')"
  [[ -n "$XUI_API_TOKEN" ]] || die "未能生成 3x-ui API Token。" "请检查 3x-ui 是否正常运行。"
  systemctl restart x-ui 2>/dev/null || true
  XUI_ACCESS_URL="https://${PANEL_DOMAIN}:${AKVPS_PANEL_PORT}/${XUI_WEB_BASE_PATH}"
  curl -kfsS --max-time 10 "https://127.0.0.1:${AKVPS_PANEL_PORT}/${XUI_WEB_BASE_PATH}" >/dev/null 2>&1 || true
}

protocol_text() {
  local out=()
  [[ "$SELECT_VLESS" -eq 1 ]] && out+=("VLESS Reality")
  [[ "$SELECT_HY2" -eq 1 ]] && out+=("Hysteria2")
  [[ "$SELECT_HY2_HOP" -eq 1 ]] && out+=("Hysteria2 端口跳跃")
  (IFS=", "; echo "${out[*]}")
}

generate_report() {
  info "生成接入报告"
  REPORT_PATH="$AKVPS_REPORT_DIR/$(date +%F-%H%M%S)-${NODE_NAME}.md"
  local status_xui status_ufw status_dns status_ssh bbr qdisc proto_lines
  status_xui="$(systemctl is-active x-ui 2>/dev/null || echo unknown)"
  status_ufw="$(ufw status 2>/dev/null | head -n1 || echo unknown)"
  status_dns="A=$PUBLIC_IPV4"
  [[ -n "$PUBLIC_IPV6" ]] && status_dns="$status_dns AAAA=$PUBLIC_IPV6"
  status_ssh="Termius 公钥已写入；密码登录已禁用"
  bbr="$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo unknown)"
  qdisc="$(sysctl -n net.core.default_qdisc 2>/dev/null || echo unknown)"
  proto_lines=""
  [[ "$SELECT_VLESS" -eq 1 ]] && proto_lines+=$'\n'"- VLESS Reality：端口 ${AKVPS_VLESS_PORT}/tcp"
  [[ "$SELECT_HY2" -eq 1 ]] && proto_lines+=$'\n'"- Hysteria2：端口 ${AKVPS_HY2_PORT}/udp"
  [[ "$SELECT_HY2_HOP" -eq 1 ]] && proto_lines+=$'\n'"- Hysteria2 端口跳跃：${AKVPS_HY2_HOP_START}-${AKVPS_HY2_HOP_END}/udp"
  cat > "$REPORT_PATH" <<EOF
# akvps 初始设置报告

## 一、节点基础

| 项目 | 内容 |
|---|---|
| 节点名称 | ${NODE_NAME} |
| 节点域名 | ${NODE_DOMAIN} |
| IPv4 | ${PUBLIC_IPV4} |
| IPv6 | ${PUBLIC_IPV6:-无} |
| 系统 | $(. /etc/os-release && echo "${PRETTY_NAME}") |
| 协议准备 | $(protocol_text) |

## 二、主控添加节点

| 字段 | 填写 |
|---|---|
| 名称 | ${NODE_NAME} |
| 备注 | ${NODE_NAME} |
| 协议 | https |
| 地址 | ${NODE_DOMAIN} |
| 端口 | ${AKVPS_XUI_PORT} |
| 基础路径 | /${XUI_WEB_BASE_PATH}/ |
| API Token | ${XUI_API_TOKEN} |
| TLS 校验 | verify |
| 入站同步 | all |
| 允许私网地址 | false |

## 三、主控建入站
${proto_lines}

## 四、本机状态

| 项目 | 状态 |
|---|---|
| DNS | ${status_dns} |
| UFW | ${status_ufw} |
| SSH | ${status_ssh} |
| BBR/FQ | ${bbr} / ${qdisc} |
| 3x-ui 服务 | ${status_xui} |
| HTTPS 地址 | ${XUI_ACCESS_URL} |
| 用户名 | ${XUI_USERNAME} |
| 密码 | ${XUI_PASSWORD} |

EOF
  chmod 600 "$REPORT_PATH"
  ln -sf "$REPORT_PATH" "$AKVPS_LATEST_REPORT"
  echo "报告已保存：$REPORT_PATH"
  cat "$REPORT_PATH"
}

generate_panel_report() {
