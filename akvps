xui_api_mock() {
  local method="$1" path="$2" data="${3:-}" id email sub_id kind link tmp
  [[ -n "$AKVPS_MOCK_STATE" && -f "$AKVPS_MOCK_STATE" ]] || return 1
  case "$method $path" in
    "GET /nodes/list")
      jq -c '{success:true,obj:.nodes}' "$AKVPS_MOCK_STATE"
      ;;
    "POST /nodes/test")
      jq -cn '{success:true,obj:{status:"online",xrayState:"running",xrayError:"",xrayVersion:"mock"}}'
      ;;
    "GET /server/getNewX25519Cert")
      jq -cn '{success:true,obj:{privateKey:"mock-private",publicKey:"mock-public"}}'
      ;;
    "GET /nodes/webCert/"*)
      jq -cn '{success:true,obj:{webCertFile:"/root/cert/aktest.example.com/fullchain.pem",webKeyFile:"/root/cert/aktest.example.com/privkey.pem"}}'
      ;;
    "GET /inbounds/list")
      jq -c '{success:true,obj:.inbounds}' "$AKVPS_MOCK_STATE"
      ;;
    "GET /inbounds/get/"*)
      id="${path##*/}"
      jq -c --argjson id "$id" '{success:true,obj:(.inbounds[]? | select(.id == $id))}' "$AKVPS_MOCK_STATE"
      ;;
    "POST /inbounds/add")
      id="$(jq '.inbounds | length + 1' "$AKVPS_MOCK_STATE")"
      tmp="$(mktemp)"
      jq --argjson inbound "$data" --argjson id "$id" '.inbounds += [($inbound + {id:$id})]' "$AKVPS_MOCK_STATE" >"$tmp" && mv "$tmp" "$AKVPS_MOCK_STATE"
      jq -cn --argjson id "$id" '{success:true,msg:"Inbound added",obj:{id:$id}}'
      ;;
    "POST /inbounds/update/"*)
      id="${path##*/}"
      tmp="$(mktemp)"
      jq --argjson inbound "$data" --argjson id "$id" '.inbounds = (.inbounds | map(if .id == $id then ($inbound + {id:$id}) else . end))' "$AKVPS_MOCK_STATE" >"$tmp" && mv "$tmp" "$AKVPS_MOCK_STATE"
      jq -cn '{success:true,msg:"Inbound updated",obj:{}}'
      ;;
    "GET /clients/get/"*)
      email="${path##*/}"
      jq -c --arg email "$email" '{success:true,obj:(.clients[]? | select(.client.email == $email))}' "$AKVPS_MOCK_STATE"
      ;;
    "POST /clients/add")
      email="$(printf "%s" "$data" | jq -r '.client.email')"
      kind="$(mock_kind_from_email "$email")"
      sub_id="${email}-sub"
      tmp="$(mktemp)"
      jq --argjson payload "$data" --arg email "$email" --arg subId "$sub_id" --arg kind "$kind" '
        .clients += [{
          client:(
            $payload.client
            + {subId:$subId, enable:true}
            + (if $kind == "vless" then {uuid:"mock-uuid",id:"mock-uuid",flow:"xtls-rprx-vision"}
               elif ($kind == "hy2" or $kind == "hy2hop") then {auth:"mock-auth",flow:""}
               else {} end)
          ),
          inboundIds:$payload.inboundIds,
          externalLinks:[]
        }]' "$AKVPS_MOCK_STATE" >"$tmp" && mv "$tmp" "$AKVPS_MOCK_STATE"
      jq -cn '{success:true,msg:"Client added",obj:{}}'
      ;;
    "POST /clients/update/"*)
      email="${path##*/}"
      email="${email%%\?*}"
      kind="$(mock_kind_from_email "$email")"
      sub_id="${email}-sub"
      tmp="$(mktemp)"
      jq --argjson client "$data" --arg email "$email" --arg kind "$kind" --arg subId "$sub_id" '
        .clients = (.clients | map(if .client.email == $email then
          .client = (
            .client
            + $client
            + {enable:true, subId:((.client.subId // $client.subId // "") as $sid | if $sid == "" then $subId else $sid end)}
            + (if $kind == "vless" then {uuid:(.client.uuid // .client.id // "mock-uuid"), id:(.client.id // .client.uuid // "mock-uuid"), flow:"xtls-rprx-vision"}
               elif ($kind == "hy2" or $kind == "hy2hop") then {auth:(.client.auth // "mock-auth"), flow:""}
               else {} end)
          )
        else . end))' "$AKVPS_MOCK_STATE" >"$tmp" && mv "$tmp" "$AKVPS_MOCK_STATE"
      jq -cn '{success:true,msg:"Client updated",obj:{}}'
      ;;
    "POST /clients/"*"/attach")
      email="${path#/clients/}"
      email="${email%/attach}"
      tmp="$(mktemp)"
      jq --arg email "$email" --argjson payload "$data" '.clients = (.clients | map(if .client.email == $email then .inboundIds = $payload.inboundIds else . end))' "$AKVPS_MOCK_STATE" >"$tmp" && mv "$tmp" "$AKVPS_MOCK_STATE"
      jq -cn '{success:true,msg:"Client attached",obj:{}}'
      ;;
    "GET /clients/links/"*)
      email="${path##*/}"
      kind="$(mock_kind_from_email "$email")"
      link="$(mock_client_link "$kind")"
      jq -cn --arg link "$link" '{success:true,obj:[$link]}'
      ;;
    "GET /clients/subLinks/"*)
      sub_id="${path##*/}"
      email="${sub_id%-sub}"
      kind="$(mock_kind_from_email "$email")"
      link="$(mock_client_link "$kind")"
      jq -cn --arg link "$link" '{success:true,obj:[$link]}'
      ;;
    *)
      jq -cn --arg path "$path" '{success:false,msg:("mock endpoint not implemented: " + $path)}'
      return 1
      ;;
  esac
}

