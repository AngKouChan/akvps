node_deploy() {
  need_root
  ensure_dirs
  load_envs
  prompt_config
  check_system
  detect_public_ips
  prompt_node
  prompt_protocols
  check_ports
  install_base_tools
  setup_ssh
  setup_swap
  prompt_tuning
  apply_tuning
  setup_ufw
  setup_dns
  wait_dns
  install_or_configure_xui
  NODE_PROTOCOLS="$(protocol_short_text)"
  save_config_var "NODE_PROTOCOLS" "$NODE_PROTOCOLS"
  generate_report
  save_state_var "ROLE_NODE" "1"
  if is_local_master_panel; then
    echo
    echo "提示：本机是主控面板，不自动接入自己。"
    echo "请在 3x-ui 主控面板里直接创建本机入站。"
  elif [[ -n "$PANEL_URL" && -n "$PANEL_API_TOKEN" ]]; then
    connect_node_to_master
  else
    echo
    echo "提示：主控信息未配置，已跳过一键接入主控。"
    echo "需要时可到 1. 基础设置 -> 3. 主控信息 导入后重新运行节点部署。"
  fi
  if [[ "$AKVPS_AUTO_DEPLOY" == "1" ]]; then
    return 0
  fi
  if [[ "$ROLE_KOMARI_AGENT" != "1" && -n "$KOMARI_ENDPOINT" ]]; then
    echo
    read -r -p "是否继续部署探针节点？[y/N] " ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
      deploy_komari
    fi
  fi
}

simple_status_word() {
  local ok="$1"
  if [[ "$ok" == "1" ]]; then
    echo "已完成"
  else
    echo "未完成"
  fi
}

show_simple_deploy_report() {
  ensure_dirs
  load_envs
  local xui_status komari_status master_status komari_status_word tuning_status
  xui_status="$(systemctl is-active x-ui 2>/dev/null || echo unknown)"
  komari_status="$(systemctl is-active komari-agent 2>/dev/null || echo unknown)"
  tuning_status="$(tuning_status_text)"
  if [[ -n "$PANEL_URL" && -n "$PANEL_API_TOKEN" && -n "$NODE_NAME" ]]; then
    if xui_api GET "/nodes/list" 2>/dev/null | jq -e --arg name "$NODE_NAME" '.obj[]? | select(.name == $name)' >/dev/null 2>&1; then
      master_status="已完成"
    else
      master_status="未确认"
    fi
  else
    master_status="未配置"
  fi
  [[ "$ROLE_KOMARI_AGENT" == "1" && "$komari_status" == "active" ]] && komari_status_word="已完成" || komari_status_word="未完成"

  info "极简报告"
  echo "- 节点域名：${NODE_DOMAIN:-未设置}"
  echo "- 节点类型：$(node_protocols_text)"
  echo "- 主控接入：$master_status"
  echo "- 探针接入：$komari_status_word"
  echo "- 运行服务：3X-UI ${xui_status} / Komari ${komari_status}"
  echo "- 调优状态：$tuning_status"
  master_inbound_status_lines || true
}

one_click_deploy() {
  need_root
  ensure_dirs
  AKVPS_AUTO_DEPLOY=1
  info "一键部署"
  echo "流程：信息注入 -> 代理节点 -> 探针节点 -> 极简报告"
  echo
  import_all_info
  load_envs
  node_deploy
  load_envs
  if [[ -n "$KOMARI_ENDPOINT" ]]; then
    deploy_komari
  else
    echo
    echo "提示：未配置探针主站地址，已跳过探针节点。"
  fi
  load_envs
  show_simple_deploy_report
  AKVPS_AUTO_DEPLOY=0
}

