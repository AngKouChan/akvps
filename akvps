  printf "%s" "$inbound_json" | jq -c '.streamSettings' | decode_json_field
}

client_exists() {
  local email="$1" encoded_email
  encoded_email="$(url_encode "$email")"
  xui_api GET "/clients/get/${encoded_email}" 2>/dev/null | jq -e '.success == true and .obj != null' >/dev/null 2>&1
}

client_get_json() {
  local email="$1" encoded_email
  encoded_email="$(url_encode "$email")"
  xui_api GET "/clients/get/${encoded_email}" 2>/dev/null | jq -c '.obj // empty'
}

client_attached_to_inbound() {
  local email="$1" inbound_id="$2" encoded_email
  encoded_email="$(url_encode "$email")"
  xui_api GET "/clients/get/${encoded_email}" 2>/dev/null | jq -e --argjson inboundId "$inbound_id" '
    .success == true and ((.obj.inboundIds // []) | index($inboundId)) != null' >/dev/null 2>&1
}

attach_client_to_inbound() {
  local email="$1" inbound_id="$2" payload response msg encoded_email
  encoded_email="$(url_encode "$email")"
  payload="$(jq -cn --argjson inboundId "$inbound_id" '{inboundIds:[$inboundId]}')"
  response="$(xui_api POST "/clients/${encoded_email}/attach" "$payload")" || return 1
  if printf "%s" "$response" | json_success; then
    echo "已绑定客户端到入站：$email"
    return 0
  fi
  msg="$(printf "%s" "$response" | jq -r '.msg // empty')"
  echo "客户端绑定失败：${msg:-unknown}"
  return 1
}

client_credentials_complete() {
  local client_json="$1" kind="$2"
  printf "%s" "$client_json" | jq -e --arg kind "$kind" '
    (.client.email // "") != ""
    and (.client.subId // "") != ""
    and (.client.enable // false) == true
    and (
      if $kind == "vless" then
        (.client.uuid // "") != ""
        and (.client.flow // "") == "xtls-rprx-vision"
      elif ($kind == "hy2" or $kind == "hy2hop") then
        (.client.auth // "") != ""
      else
        true
      end
    )' >/dev/null 2>&1
}

client_update_payload() {
  local client_json="$1" kind="$2" flow="${3:-}"
  printf "%s" "$client_json" | jq -c --arg kind "$kind" --arg flow "$flow" '
    .client
    | .enable = true
    | .totalGB = (.totalGB // 0)
    | .expiryTime = (.expiryTime // 0)
    | .tgId = (.tgId // 0)
    | .limitIp = (.limitIp // 0)
    | .comment = (.comment // "")
    | .reset = (.reset // 0)
    | .group = (.group // "")
    | if $kind == "vless" then
        .id = ((.uuid // (if ((.id // null) | type) == "string" then .id else "" end) // "") | tostring)
        | .flow = $flow
      else
        .flow = ""
      end'
}

repair_master_client() {
  local email="$1" kind="$2" flow="$3" inbound_id="${4:-}" client_json payload response msg encoded_email update_path
  encoded_email="$(url_encode "$email")"
  client_json="$(client_get_json "$email")" || return 1
  [[ -n "$client_json" ]] || return 1
  if client_credentials_complete "$client_json" "$kind"; then
    return 0
  fi
  payload="$(client_update_payload "$client_json" "$kind" "$flow")"
  update_path="/clients/update/${encoded_email}"
  [[ -n "$inbound_id" ]] && update_path="${update_path}?inboundIds=${inbound_id}"
  response="$(xui_api POST "$update_path" "$payload")" || return 1
  if printf "%s" "$response" | json_success; then
    echo "已修正客户端资料：$email"
    client_json="$(client_get_json "$email")" || return 1
    client_credentials_complete "$client_json" "$kind" || {
      echo "客户端资料仍不完整：$email"
      return 1
    }
    return 0
  fi
  msg="$(printf "%s" "$response" | jq -r '.msg // empty')"
  echo "客户端资料修正失败：${msg:-unknown}"
  return 1
}

expected_client_link_scheme() {
  case "$1" in
    vless) printf "vless://" ;;
    hy2|hy2hop) printf "hysteria2://" ;;
    *) printf "" ;;
  esac
}

client_links_are_complete() {
  local response="$1" kind="$2" scheme="$3" hop_ports
  printf "%s" "$response" | jq -e --arg scheme "$scheme" '
    def links:
      if (.obj | type) == "array" then .obj
      elif (.obj | type) == "string" then (.obj | split("\n") | map(select(length > 0)))
      else []
      end;
    .success == true
    and any(links[]; type == "string" and startswith($scheme))' >/dev/null 2>&1 || return 1
  if [[ "$kind" == "vless" ]]; then
    printf "%s" "$response" | jq -e --arg scheme "$scheme" '
      def links:
        if (.obj | type) == "array" then .obj
        elif (.obj | type) == "string" then (.obj | split("\n") | map(select(length > 0)))
        else []
        end;
      .success == true
      and any(links[];
        type == "string"
        and startswith($scheme)
        and contains("type=tcp")
        and contains("security=reality")
        and contains("encryption=none")
        and contains("pbk=")
        and contains("sid=")
        and contains("sni=")
        and contains("fp=")
        and contains("flow=xtls-rprx-vision")
      )' >/dev/null 2>&1 || return 1
  fi
  if [[ "$kind" == "hy2" || "$kind" == "hy2hop" ]]; then
    printf "%s" "$response" | jq -e --arg scheme "$scheme" '
      def links:
        if (.obj | type) == "array" then .obj
        elif (.obj | type) == "string" then (.obj | split("\n") | map(select(length > 0)))
        else []
        end;
      .success == true
      and any(links[];
        type == "string"
        and startswith($scheme)
        and contains("security=tls")
      )' >/dev/null 2>&1 || return 1
  fi
  if [[ "$kind" == "hy2hop" ]]; then
    hop_ports="${AKVPS_HY2_HOP_START}-${AKVPS_HY2_HOP_END}"
    printf "%s" "$response" | jq -e --arg scheme "$scheme" --arg ports "$hop_ports" '
      def links:
        if (.obj | type) == "array" then .obj
        elif (.obj | type) == "string" then (.obj | split("\n") | map(select(length > 0)))
        else []
        end;
      .success == true
      and any(links[]; type == "string" and startswith($scheme) and contains("mport=" + $ports))' >/dev/null 2>&1 || return 1
  fi
}

verify_client_links() {
  local email="$1" kind="$2" scheme response client_json sub_id hop_ports encoded_email encoded_sub_id
  scheme="$(expected_client_link_scheme "$kind")"
  [[ -n "$scheme" ]] || return 0
  encoded_email="$(url_encode "$email")"
  response="$(xui_api GET "/clients/links/${encoded_email}" 2>/dev/null || true)"
  client_links_are_complete "$response" "$kind" "$scheme" || {
    echo "客户端链接未生成：$email"
    if [[ "$kind" == "hy2hop" ]]; then
      hop_ports="${AKVPS_HY2_HOP_START}-${AKVPS_HY2_HOP_END}"
      echo "端口跳跃链接还应包含：mport=${hop_ports}"
    fi
    return 1
  }
  echo "客户端链接已生成：$email"
  client_json="$(client_get_json "$email")" || return 1
  sub_id="$(printf "%s" "$client_json" | jq -r '.client.subId // empty')"
  [[ -n "$sub_id" ]] || {
    echo "客户端订阅 ID 未生成：$email"
    return 1
  }
  encoded_sub_id="$(url_encode "$sub_id")"
  response="$(xui_api GET "/clients/subLinks/${encoded_sub_id}" 2>/dev/null || true)"
  client_links_are_complete "$response" "$kind" "$scheme" || {
    echo "客户端订阅链接未生成：$email"
    if [[ "$kind" == "hy2hop" ]]; then
      hop_ports="${AKVPS_HY2_HOP_START}-${AKVPS_HY2_HOP_END}"
      echo "端口跳跃订阅还应包含：mport=${hop_ports}"
    fi
    return 1
  }
  echo "客户端订阅链接已生成：$email"
}

client_link_status_word() {
  local email="$1" kind="$2" scheme response encoded_email
  scheme="$(expected_client_link_scheme "$kind")"
  [[ -n "$scheme" ]] || {
    printf "不适用"
    return
  }
  encoded_email="$(url_encode "$email")"
  response="$(xui_api GET "/clients/links/${encoded_email}" 2>/dev/null || true)"
  if client_links_are_complete "$response" "$kind" "$scheme"; then
    printf "已生成"
  else
    printf "未生成"
  fi
}

master_inbound_status_lines() {
  load_envs
  require_tools_for_json
  local proto tag inbound_id kind email link_status any=0 want_vless want_hy2 want_hy2hop
  proto="${NODE_PROTOCOLS:-$(node_protocols_text)}"
  parse_protocols "$proto"
  want_vless="$SELECT_VLESS"
  want_hy2="$SELECT_HY2"
  want_hy2hop="$SELECT_HY2_HOP"
  [[ -n "$PANEL_URL" && -n "$PANEL_API_TOKEN" && -n "$NODE_NAME" ]] || {
    echo "- 主控自动接入：未配置"
    return 0
  }
  echo "- 主控节点：$(xui_api GET "/nodes/list" 2>/dev/null | jq -r --arg name "$NODE_NAME" 'if [.obj[]? | select(.name == $name)] | length > 0 then "已存在" else "未找到" end' 2>/dev/null || echo "未确认")"
  for kind in vless hy2 hy2hop; do
    case "$kind" in
      vless)
        [[ "$want_vless" -eq 1 ]] || continue
        tag="akvps-${NODE_NAME}-vless"
        email="$(client_email_for_kind vless)"
        ;;
      hy2)
        [[ "$want_hy2" -eq 1 ]] || continue
        tag="akvps-${NODE_NAME}-hy2"
        email="$(client_email_for_kind hy2)"
        ;;
      hy2hop)
        [[ "$want_hy2hop" -eq 1 ]] || continue
        tag="akvps-${NODE_NAME}-hy2hop"
        email="$(client_email_for_kind hy2hop)"
        ;;
    esac
    any=1
    inbound_id="$(master_inbound_id_by_tag "$tag" 2>/dev/null || true)"
    if [[ -n "$inbound_id" ]]; then
      if client_exists "$email" && ! client_credentials_complete "$(client_get_json "$email")" "$kind"; then
        link_status="资料不完整"
      else
        link_status="$(client_link_status_word "$email" "$kind")"
      fi
      echo "- ${kind} 入站：已存在；客户端：${email}；链接：${link_status}"
    else
      echo "- ${kind} 入站：未找到；客户端：${email}；链接：未确认"
    fi
  done
  [[ "$any" -eq 1 ]] || echo "- 主控入站：未记录节点协议"
}

build_client_payload() {
  local email="$1" inbound_id="$2" flow="${3:-}" sub_id
  sub_id="$(client_sub_id_for_email "$email")"
  jq -cn \
    --arg email "$email" \
    --arg flow "$flow" \
    --arg subId "$sub_id" \
    --argjson inboundId "$inbound_id" \
    '{
      client: ({
        email:$email,
        subId:$subId,
        totalGB:0,
        expiryTime:0,
        tgId:0,
        limitIp:0,
        enable:true,
        comment:"",
        reset:0
      } + (if $flow != "" then {flow:$flow} else {} end)),
      inboundIds:[$inboundId]
    }'
}

ensure_master_client() {
  local inbound_id="$1" kind="$2" email flow payload response msg
  case "$kind" in
    vless)
      email="$(client_email_for_kind vless)"
      flow="xtls-rprx-vision"
      ;;
    hy2)
      email="$(client_email_for_kind hy2)"
      flow=""
      ;;
    hy2hop)
      email="$(client_email_for_kind hy2hop)"
      flow=""
      ;;
    *)
      return 0
      ;;
  esac
  if client_exists "$email"; then
    if client_attached_to_inbound "$email" "$inbound_id"; then
      echo "客户端已存在：$email"
    else
      attach_client_to_inbound "$email" "$inbound_id" || return 1
    fi
    repair_master_client "$email" "$kind" "$flow" "$inbound_id" || return 1
    verify_client_links "$email" "$kind" || return 1
    return 0
  fi
  payload="$(build_client_payload "$email" "$inbound_id" "$flow")"
  response="$(xui_api POST "/clients/add" "$payload")" || return 1
  if printf "%s" "$response" | json_success; then
    echo "已创建客户端：$email"
    repair_master_client "$email" "$kind" "$flow" "$inbound_id" || return 1
    verify_client_links "$email" "$kind" || return 1
    return 0
  fi
  msg="$(printf "%s" "$response" | jq -r '.msg // empty')"
  echo "客户端创建失败：${msg:-unknown}"
  return 1
}

build_minimal_inbound_payload() {
  local node_id="$1" kind="$2" tag="$3" remark="$4" port="$5" inbound_id="${6:-0}" existing_json="${7:-}"
  local protocol settings stream sniffing short_id key_pair private_key public_key
  local old_settings old_stream old_private old_public old_short_ids old_target old_server_names cert_pair cert_file key_file
  old_settings="$(existing_inbound_settings "$existing_json")"
  old_stream="$(existing_inbound_stream "$existing_json")"
  sniffing='{"enabled":true,"destOverride":["http","tls","quic","fakedns"],"metadataOnly":false,"routeOnly":false,"ipsExcluded":[],"domainsExcluded":[]}'
  case "$kind" in
    vless)
      protocol="vless"
      short_id="$(random_string 8)"
      key_pair="$(generate_reality_keys_from_master 2>/dev/null || generate_reality_keys)"
      private_key="${key_pair%%|*}"
      public_key="${key_pair#*|}"
      old_private="$(printf "%s" "$old_stream" | jq -r '.realitySettings.privateKey // empty')"
      old_public="$(printf "%s" "$old_stream" | jq -r '.realitySettings.settings.publicKey // empty')"
      old_short_ids="$(printf "%s" "$old_stream" | jq -c '.realitySettings.shortIds // []')"
      old_target="$(printf "%s" "$old_stream" | jq -r '.realitySettings.target // .realitySettings.dest // empty')"
      old_server_names="$(printf "%s" "$old_stream" | jq -c '.realitySettings.serverNames // []')"
      [[ -n "$old_private" ]] && private_key="$old_private"
      [[ -n "$old_public" ]] && public_key="$old_public"
      [[ "$(printf "%s" "$old_short_ids" | jq 'length')" -gt 0 ]] && short_id="$(printf "%s" "$old_short_ids" | jq -r '.[0]')"
      settings="$(printf "%s" "$old_settings" | jq -c '{clients:(.clients // []),decryption:"none",encryption:"none",fallbacks:(.fallbacks // []),testseed:(.testseed // [900,500,900,256])}')"
      stream="$(jq -cn \
        --arg privateKey "$private_key" \
        --arg publicKey "$public_key" \
        --arg shortId "$short_id" \
        --arg target "${old_target:-www.microsoft.com:443}" \
        --argjson serverNames "${old_server_names:-[]}" \
        '{
          network:"tcp",
          security:"reality",
          tcpSettings:{acceptProxyProtocol:false,header:{type:"none"}},
          realitySettings:{
            show:false,
            xver:0,
            target:$target,
            dest:$target,
            serverNames:(if ($serverNames | length) > 0 then $serverNames else ["www.microsoft.com"] end),
            privateKey:$privateKey,
            minClientVer:"",
            maxClientVer:"",
            maxTimediff:0,
            shortIds:[$shortId],
            mldsa65Seed:"",
            settings:{publicKey:$publicKey,fingerprint:"chrome",serverName:"",spiderX:"/",mldsa65Verify:""}
          }
        }')"
      ;;
    hy2|hy2hop)
      protocol="hysteria"
      settings="$(printf "%s" "$old_settings" | jq -c '{version:2,clients:(.clients // [])}')"
      cert_pair="$(node_web_cert_files "$node_id")"
      cert_file="${cert_pair%%|*}"
      key_file="${cert_pair#*|}"
      if [[ "$kind" == "hy2hop" ]]; then
        stream="$(jq -cn \
          --argjson old "$old_stream" \
          --arg ports "${AKVPS_HY2_HOP_START}-${AKVPS_HY2_HOP_END}" \
          --arg certFile "$cert_file" \
          --arg keyFile "$key_file" \
          '$old
          + {
            network:"hysteria",
            security:($old.security // "tls"),
            hysteriaSettings:(($old.hysteriaSettings // {}) + {
              version:2,
              auth:($old.hysteriaSettings.auth // ""),
              udpIdleTimeout:($old.hysteriaSettings.udpIdleTimeout // 60),
              masquerade:($old.hysteriaSettings.masquerade // {type:"",dir:"",url:"",rewriteHost:false,insecure:false,content:"",headers:{},statusCode:0}),
              finalmask:(
                ($old.hysteriaSettings.finalmask // {})
                * {quicParams:{udpHop:{
                  ports:$ports,
                  interval:($old.hysteriaSettings.finalmask.quicParams.udpHop.interval // $old.finalmask.quicParams.udpHop.interval // "5-10")
                }}}
              )
            }),
            tlsSettings:(
              ($old.tlsSettings // {})
              + {
                serverName:($old.tlsSettings.serverName // ""),
                minVersion:($old.tlsSettings.minVersion // "1.2"),
                maxVersion:($old.tlsSettings.maxVersion // "1.3"),
                cipherSuites:($old.tlsSettings.cipherSuites // ""),
                rejectUnknownSni:($old.tlsSettings.rejectUnknownSni // false),
                disableSystemRoot:($old.tlsSettings.disableSystemRoot // false),
                enableSessionResumption:($old.tlsSettings.enableSessionResumption // false),
                alpn:($old.tlsSettings.alpn // ["h3"]),
                echServerKeys:($old.tlsSettings.echServerKeys // ""),
                settings:($old.tlsSettings.settings // {fingerprint:"",echConfigList:"",pinnedPeerCertSha256:[]}),
                certificates:(
                  if (($old.tlsSettings.certificates // []) | length) > 0 then
                    $old.tlsSettings.certificates
                  else
                    [{certificateFile:$certFile,keyFile:$keyFile,certificate:[],key:[],ocspStapling:3600,oneTimeLoading:false,usage:"encipherment",buildChain:false}]
                  end
                )
              }
            ),
            finalmask:(
              ($old.finalmask // {})
              * {quicParams:{udpHop:{
                ports:$ports,
                interval:($old.finalmask.quicParams.udpHop.interval // $old.hysteriaSettings.finalmask.quicParams.udpHop.interval // "5-10")
              }}}
            )
          }')"
      else
        stream="$(jq -cn \
          --argjson old "$old_stream" \
          --arg certFile "$cert_file" \
          --arg keyFile "$key_file" \
          '$old
          + {
            network:"hysteria",
            security:($old.security // "tls"),
            hysteriaSettings:(($old.hysteriaSettings // {}) + {
              version:2,
              auth:($old.hysteriaSettings.auth // ""),
              udpIdleTimeout:($old.hysteriaSettings.udpIdleTimeout // 60),
              masquerade:($old.hysteriaSettings.masquerade // {type:"",dir:"",url:"",rewriteHost:false,insecure:false,content:"",headers:{},statusCode:0})
            }),
            tlsSettings:(
              ($old.tlsSettings // {})
              + {
                serverName:($old.tlsSettings.serverName // ""),
                minVersion:($old.tlsSettings.minVersion // "1.2"),
                maxVersion:($old.tlsSettings.maxVersion // "1.3"),
                cipherSuites:($old.tlsSettings.cipherSuites // ""),
                rejectUnknownSni:($old.tlsSettings.rejectUnknownSni // false),
                disableSystemRoot:($old.tlsSettings.disableSystemRoot // false),
                enableSessionResumption:($old.tlsSettings.enableSessionResumption // false),
                alpn:($old.tlsSettings.alpn // ["h3"]),
                echServerKeys:($old.tlsSettings.echServerKeys // ""),
                settings:($old.tlsSettings.settings // {fingerprint:"",echConfigList:"",pinnedPeerCertSha256:[]}),
                certificates:(
                  if (($old.tlsSettings.certificates // []) | length) > 0 then
                    $old.tlsSettings.certificates
                  else
                    [{certificateFile:$certFile,keyFile:$keyFile,certificate:[],key:[],ocspStapling:3600,oneTimeLoading:false,usage:"encipherment",buildChain:false}]
                  end
                )
              }
            )
          }')"
      fi
      ;;
    *)
      return 1
      ;;
  esac
  jq -n \
    --arg remark "$remark" \
    --arg protocol "$protocol" \
    --arg settings "$settings" \
    --arg streamSettings "$stream" \
    --arg tag "$tag" \
    --arg sniffing "$sniffing" \
    --argjson id "$inbound_id" \
    --argjson nodeId "$node_id" \
    --argjson port "$port" \
    '{
      id: $id,
      up: 0,
      down: 0,
      total: 0,
      remark: $remark,
      enable: true,
      expiryTime: 0,
      listen: "",
      port: $port,
      protocol: $protocol,
      settings: $settings,
      streamSettings: $streamSettings,
      tag: $tag,
      sniffing: $sniffing,
      nodeId: $nodeId,
      trafficReset: "never",
      shareAddrStrategy: "node",
      shareAddr: ""
    }'
}

ensure_master_inbound() {
  local node_id="$1" kind="$2" tag="$3" remark="$4" port="$5" payload response msg inbound_id path action existing_json
  inbound_id="$(master_inbound_id_by_tag "$tag" 2>/dev/null || true)"
  if [[ -n "$inbound_id" ]]; then
    existing_json="$(master_inbound_by_id "$inbound_id" 2>/dev/null || true)"
    path="/inbounds/update/${inbound_id}"
    action="已更新"
  else
    inbound_id=0
    existing_json=""
    path="/inbounds/add"
    action="已创建"
  fi
  payload="$(build_minimal_inbound_payload "$node_id" "$kind" "$tag" "$remark" "$port" "$inbound_id" "$existing_json")" || return 1
  response="$(xui_api POST "$path" "$payload")" || return 1
  if printf "%s" "$response" | json_success; then
    echo "${action}入站：$remark"
    if [[ "$inbound_id" == "0" ]]; then
      inbound_id="$(printf "%s" "$response" | jq -r '.obj.id // empty')"
      [[ -n "$inbound_id" ]] || inbound_id="$(master_inbound_id_by_tag "$tag" 2>/dev/null || true)"
    fi
    [[ -n "$inbound_id" ]] || {
      echo "入站已保存，但无法确认入站 ID：$tag"
      return 1
    }
    if ! master_inbound_saved_complete "$inbound_id" "$kind" "$node_id"; then
      echo "入站保存后字段不完整：$remark"
      return 1
    fi
    ensure_master_client "$inbound_id" "$kind" || return 1
    return 0
  fi
  msg="$(printf "%s" "$response" | jq -r '.msg // empty')"
  echo "入站保存失败：${msg:-unknown}"
  return 1
}

ensure_master_inbounds() {
  load_envs
  local node_id proto ok=1 want_vless want_hy2 want_hy2hop
  proto="${NODE_PROTOCOLS:-$(node_protocols_text)}"
  parse_protocols "$proto"
  want_vless="$SELECT_VLESS"
  want_hy2="$SELECT_HY2"
  want_hy2hop="$SELECT_HY2_HOP"
  node_id="$(master_node_id 2>/dev/null || true)"
  [[ -n "$node_id" ]] || {
    echo "未找到主控节点 ID，跳过自动建入站。"
    return 1
  }
  info "自动创建主控入站"
  if [[ -z "$proto" || "$proto" == "未记录" ]]; then
    echo "缺少节点类型，暂时无法自动建入站。"
    echo "建议：重新运行一次代理节点部署，或手动在主控建入站。"
    return 1
  fi
  echo "节点类型：$proto"
  if [[ "$want_vless" -eq 1 ]]; then
    ensure_master_inbound "$node_id" "vless" "akvps-${NODE_NAME}-vless" "${NODE_NAME} vless" "$AKVPS_VLESS_PORT" || ok=0
  fi
  if [[ "$want_hy2" -eq 1 ]]; then
    ensure_master_inbound "$node_id" "hy2" "akvps-${NODE_NAME}-hy2" "${NODE_NAME} hy2" "$AKVPS_HY2_PORT" || ok=0
  fi
  if [[ "$want_hy2hop" -eq 1 ]]; then
    ensure_master_inbound "$node_id" "hy2hop" "akvps-${NODE_NAME}-hy2hop" "${NODE_NAME} hy2端口跳跃" "$AKVPS_HY2_HOP_START" || ok=0
  fi
  [[ "$ok" -eq 1 ]] || {
    echo "提示：有入站未自动创建成功，可先在主控面板手动补。"
    return 1
  }
}

verify_master_node_runtime() {
  local payload response status xray_state msg i
  payload="$(build_node_payload)"
  for i in $(seq 1 6); do
    response="$(xui_api POST "/nodes/test" "$payload")" || return 1
    status="$(printf "%s" "$response" | jq -r '.obj.status // empty')"
    xray_state="$(printf "%s" "$response" | jq -r '.obj.xrayState // .obj.xray.state // empty')"
    msg="$(printf "%s" "$response" | jq -r '.obj.error // .obj.xrayError // .obj.xray.errorMsg // .msg // empty')"
    if [[ "$status" == "online" && "$xray_state" != "failed" && "$xray_state" != "error" ]]; then
      echo "验证通过：远端节点在线，Xray 状态正常。"
      return 0
    fi
    echo "等待远端节点同步配置... $i/6"
    sleep 5
  done
  echo "远端节点同步后仍未确认正常：${msg:-unknown}"
  return 1
}

connect_node_to_master() {
  need_root
  ensure_dirs
  load_envs
  require_tools_for_json
  [[ -n "$PANEL_URL" ]] || die "缺少主控面板地址。" "请先到 1. 基础设置 -> 3. 主控信息 导入 PANEL_URL。"
  [[ -n "$PANEL_API_TOKEN" ]] || die "缺少主控 API Token。" "请先到 1. 基础设置 -> 3. 主控信息 导入 PANEL_API_TOKEN。"
  [[ -n "$NODE_NAME" && -n "$NODE_DOMAIN" && -n "$NODE_XUI_API_TOKEN" ]] || die "缺少当前节点信息。" "请先运行 2. 本机部署 -> 1. 代理节点。"

  info "测试节点连通"
  local payload response status xray_state msg i
  payload="$(build_node_payload)"
  for i in $(seq 1 12); do
    response="$(xui_api POST "/nodes/test" "$payload")" || die "无法连接主控面板 API。" "如果上面显示 HTTP 401/403，请重新导入主控机卡片里的完整 PANEL_API_TOKEN。"
    status="$(printf "%s" "$response" | jq -r '.obj.status // empty')"
    xray_state="$(printf "%s" "$response" | jq -r '.obj.xrayState // .obj.xray.state // empty')"
    msg="$(printf "%s" "$response" | jq -r '.obj.error // .obj.xrayError // .obj.xray.errorMsg // .msg // empty')"
    [[ "$status" == "online" && "$xray_state" != "failed" && "$xray_state" != "error" ]] && break
    echo "节点暂未就绪，等待重试... $i/12"
    sleep 5
  done
  [[ "$status" == "online" && "$xray_state" != "failed" && "$xray_state" != "error" ]] || die "主控未确认节点和 Xray 正常。" "请检查节点域名、11123 端口、节点 API Token、Xray 状态。主控返回：${msg:-unknown}"

  info "接入主控面板"
  local existing_id action
  existing_id="$(xui_api GET "/nodes/list" | jq -r --arg name "$NODE_NAME" '.obj[]? | select(.name == $name) | .id' | head -n1)" || existing_id=""
  if [[ -n "$existing_id" ]]; then
    response="$(xui_api POST "/nodes/update/${existing_id}" "$payload")" || die "主控更新节点失败。" "请重新导入主控机卡片里的完整 PANEL_API_TOKEN。"
    action="已更新"
  else
    response="$(xui_api POST "/nodes/add" "$payload")" || die "主控添加节点失败。" "请重新导入主控机卡片里的完整 PANEL_API_TOKEN。"
    action="已添加"
  fi
  if printf "%s" "$response" | json_success; then
    echo "${action}主控节点：$NODE_NAME"
  else
    msg="$(printf "%s" "$response" | jq -r '.msg // empty')"
    die "主控接入节点失败。" "主控返回：${msg:-unknown}"
  fi

  info "验证主控接入"
  existing_id="$(xui_api GET "/nodes/list" | jq -r --arg name "$NODE_NAME" '.obj[]? | select(.name == $name) | .id' | head -n1)" || existing_id=""
  [[ -n "$existing_id" ]] || die "主控列表里没有找到这个节点。" "请稍后在主控面板节点列表确认，或重新运行节点部署。"
  echo "验证通过：主控已存在节点 $NODE_NAME"
  ensure_master_inbounds || die "主控入站或客户端未完整生成。" "请查看上面的失败项；修正后可重新运行验证接入。"
  verify_master_node_runtime || die "主控已保存配置，但远端节点未确认正常。" "请查看 3x-ui 节点错误信息，修正后重新运行验证接入。"
  master_inbound_status_lines || true
}

