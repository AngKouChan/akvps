  [[ -n "$inbound_json" ]] || return 1
  printf "%s" "$inbound_json" | jq -e --arg kind "$kind" --argjson nodeId "$node_id" --arg ports "${AKVPS_HY2_HOP_START}-${AKVPS_HY2_HOP_END}" '
    def json_obj:
      if type == "string" then (fromjson? // {})
      elif type == "object" then .
      else {}
      end;
    (.settings | json_obj) as $settings
    | (.streamSettings | json_obj) as $stream
    |
    .nodeId == $nodeId
    and .shareAddrStrategy == "node"
    and (.shareAddr // "") == ""
    and (
      if $kind == "vless" then
        .protocol == "vless"
        and ($settings.decryption // "") == "none"
        and ($settings.encryption // "") == "none"
        and ($stream.network // "") == "tcp"
        and ($stream.security // "") == "reality"
        and (($stream.realitySettings.target // "") | test(":[0-9]+$"))
        and (($stream.realitySettings.dest // "") | test(":[0-9]+$"))
        and (($stream.realitySettings.privateKey // "") != "")
        and (($stream.realitySettings.settings.publicKey // "") != "")
        and (($stream.realitySettings.settings.fingerprint // "") != "")
        and (($stream.realitySettings.shortIds // []) | length > 0)
        and all(($stream.realitySettings.shortIds // [])[]; type == "string" and length > 0)
        and (($stream.realitySettings.serverNames // []) | length > 0)
        and all(($stream.realitySettings.serverNames // [])[]; type == "string" and length > 0)
      elif ($kind == "hy2" or $kind == "hy2hop") then
        .protocol == "hysteria"
        and ($settings.version // 0) == 2
        and ($stream.network // "") == "hysteria"
        and ($stream.security // "") == "tls"
        and (($stream.tlsSettings.alpn // []) | index("h3") != null)
        and (($stream.tlsSettings.certificates[0].certificateFile // "") != "")
        and (($stream.tlsSettings.certificates[0].keyFile // "") != "")
        and (if $kind == "hy2hop" then
          ($stream.finalmask.quicParams.udpHop.ports // "") == $ports
          and ($stream.hysteriaSettings.finalmask.quicParams.udpHop.ports // "") == $ports
        else true end)
      else
        true
      end
    )' >/dev/null 2>&1
}

