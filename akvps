slash_join_roles() {
  local out=()
  [[ "$ROLE_MASTER_PANEL" == "1" ]] && out+=("主控面板")
  [[ "$ROLE_KOMARI_SERVER" == "1" ]] && out+=("探针主站")
  [[ "$ROLE_NODE" == "1" ]] && out+=("代理节点")
  [[ "$ROLE_KOMARI_AGENT" == "1" ]] && out+=("探针节点")
  if ((${#out[@]} == 0)); then
    echo "未部署"
  else
    local joined="${out[0]}" i
    for ((i = 1; i < ${#out[@]}; i++)); do
      joined="$joined / ${out[$i]}"
    done
    echo "$joined"
  fi
}

