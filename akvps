setup_swap() {
  info "检查 Swap"
  if swapon --show | grep -q .; then
    echo "已有 Swap，跳过。"
    return
  fi
  local mem_kb mem_mb
  mem_kb="$(awk '/MemTotal/ {print $2}' /proc/meminfo)"
  mem_mb=$((mem_kb / 1024))
  if (( mem_mb > 4096 )); then
    echo "内存大于 4G，默认不创建 Swap。"
    return
  fi
  if [[ "$AKVPS_AUTO_DEPLOY" == "1" ]]; then
    echo "一键部署：自动创建 1G Swap。"
    fallocate -l 1G /swapfile || dd if=/dev/zero of=/swapfile bs=1M count=1024
    chmod 600 /swapfile
    mkswap /swapfile
    swapon /swapfile
    grep -q '^/swapfile ' /etc/fstab || echo '/swapfile none swap sw 0 0' >> /etc/fstab
    return
  fi
  read -r -p "建议创建 1G Swap，是否创建？[Y/n] " ans
  ans="${ans:-Y}"
  [[ "$ans" =~ ^[Yy]$ ]] || return
  fallocate -l 1G /swapfile || dd if=/dev/zero of=/swapfile bs=1M count=1024
  chmod 600 /swapfile
  mkswap /swapfile
  swapon /swapfile
  grep -q '^/swapfile ' /etc/fstab || echo '/swapfile none swap sw 0 0' >> /etc/fstab
}

prompt_tuning() {
  info "调优选择"
  if [[ "$AKVPS_AUTO_DEPLOY" == "1" && -n "$RTT_MS" ]]; then
    TUNING_MODE="${TUNING_MODE:-smart}"
    LOCAL_DOWN_MBPS="${LOCAL_DOWN_MBPS:-1000}"
    LOCAL_UP_MBPS="${LOCAL_UP_MBPS:-50}"
    VPS_MBPS="${VPS_MBPS:-1000}"
    LINE_QUALITY="${LINE_QUALITY:-1}"
    echo "调优：智能；VPS ${VPS_MBPS}Mbps；延迟 ${RTT_MS}ms；线路质量 ${LINE_QUALITY}"
    return
  fi
  read -r -p "是否启用智能调优？[Y/n] " ans
  ans="${ans:-Y}"
  if [[ "$ans" =~ ^[Nn]$ ]]; then
    TUNING_MODE="basic"
    return
  fi
  TUNING_MODE="smart"
  read -r -p "本地下载 Mbps [1000]: " v
  LOCAL_DOWN_MBPS="${v:-1000}"
  read -r -p "本地上传 Mbps [50]: " v
  LOCAL_UP_MBPS="${v:-50}"
  read -r -p "VPS 标称 Mbps [1000]: " v
  VPS_MBPS="${v:-1000}"
  while [[ -z "$RTT_MS" ]]; do
    read -r -p "本地到 VPS 平均 ping 延迟 ms（必填，可填大概值）: " RTT_MS
  done
  echo "线路质量："
  echo "1. 稳定"
  echo "2. 波动"
  echo "3. 丢包明显"
  read -r -p "请选择 [1]: " LINE_QUALITY
  LINE_QUALITY="${LINE_QUALITY:-1}"
}

apply_tuning() {
  info "应用系统调优"
  [[ -f "$AKVPS_SYSCTL" ]] && cp -a "$AKVPS_SYSCTL" "$AKVPS_SYSCTL.bak.$(date +%F-%H%M%S)"
  local mem_kb mem_mb tcp_mem udp_mem rmem_max wmem_max
  mem_kb="$(awk '/MemTotal/ {print $2}' /proc/meminfo)"
  mem_mb=$((mem_kb / 1024))
  rmem_max=67108864
  wmem_max=67108864
  if [[ "$TUNING_MODE" == "smart" ]]; then
    if (( VPS_MBPS >= 1000 && RTT_MS >= 150 )); then
      rmem_max=134217728
      wmem_max=134217728
    fi
    if [[ "$LINE_QUALITY" == "3" ]]; then
      rmem_max=67108864
      wmem_max=67108864
    fi
  fi
  tcp_mem="786432 1048576 1572864"
  udp_mem="262144 524288 1048576"
  if (( mem_mb < 1024 )); then
    tcp_mem="196608 262144 393216"
    udp_mem="65536 131072 262144"
    rmem_max=33554432
    wmem_max=33554432
  fi
  cat > "$AKVPS_SYSCTL" <<EOF
net.core.default_qdisc=fq
net.ipv4.tcp_congestion_control=bbr
net.core.rmem_max=$rmem_max
net.core.wmem_max=$wmem_max
net.ipv4.tcp_rmem=4096 87380 $rmem_max
net.ipv4.tcp_wmem=4096 65536 $wmem_max
net.ipv4.tcp_mtu_probing=1
net.ipv4.tcp_fastopen=3
net.ipv4.tcp_mem=$tcp_mem
net.ipv4.udp_mem=$udp_mem
net.core.somaxconn=4096
net.ipv4.ip_local_port_range=1024 65535
EOF
  sysctl --system >/dev/null
  sysctl net.ipv4.tcp_congestion_control net.core.default_qdisc
}

setup_ufw() {
  info "配置 UFW"
  local ssh_port
  ssh_port="$(detect_ssh_port)"
  ufw --force reset
  ufw default deny incoming
  ufw default allow outgoing
  ufw allow "$ssh_port/tcp" comment "ssh"
  ufw allow 80/tcp comment "acme"
  ufw allow 443/tcp comment "https"
  ufw allow from "$MASTER_IPV4" to any port "$AKVPS_XUI_PORT" proto tcp comment "akvps x-ui master"
  [[ -n "$MASTER_IPV6" ]] && ufw allow from "$MASTER_IPV6" to any port "$AKVPS_XUI_PORT" proto tcp comment "akvps x-ui master ipv6"
  [[ "$SELECT_VLESS" -eq 1 ]] && ufw allow "$AKVPS_VLESS_PORT/tcp" comment "vless reality"
  [[ "$SELECT_HY2" -eq 1 ]] && ufw allow "$AKVPS_HY2_PORT/udp" comment "hysteria2"
  [[ "$SELECT_HY2_HOP" -eq 1 ]] && ufw allow "$AKVPS_HY2_HOP_START:$AKVPS_HY2_HOP_END/udp" comment "hysteria2 hop"
  ufw --force enable
  ufw reload
}

