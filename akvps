prompt_komari() {
  info "Komari 探针信息"
  while true; do
    read -r -p "请输入 Komari 面板地址，例如 https://status.kouzho.cc: " KOMARI_ENDPOINT
    KOMARI_ENDPOINT="${KOMARI_ENDPOINT%/}"
    [[ "$KOMARI_ENDPOINT" =~ ^https?://[^[:space:]]+$ ]] && break
    echo "地址格式不正确，请以 http:// 或 https:// 开头。"
  done
  while [[ -z "$KOMARI_TOKEN" ]]; do
    read -r -s -p "请输入 Komari 节点 Token: " KOMARI_TOKEN
    echo
  done
  save_config_var "KOMARI_ENDPOINT" "$KOMARI_ENDPOINT"
  save_secret_var "KOMARI_TOKEN" "$KOMARI_TOKEN"
}

deploy_komari_agent() {
  info "安装 Komari 探针"
  bash <(curl -fsSL https://raw.githubusercontent.com/komari-monitor/komari-agent/main/install.sh) \
    -e "$KOMARI_ENDPOINT" \
    -t "$KOMARI_TOKEN" \
    --disable-web-ssh
}

generate_komari_report() {
  info "生成 Komari 探针卡片"
  KOMARI_REPORT_PATH="$AKVPS_REPORT_DIR/$(date +%F-%H%M%S)-komari-agent.md"
  local status_agent token_masked
  status_agent="$(systemctl is-active komari-agent 2>/dev/null || echo unknown)"
  token_masked="${KOMARI_TOKEN:0:6}******${KOMARI_TOKEN: -4}"
  cat > "$KOMARI_REPORT_PATH" <<EOF
# akvps Komari 探针卡片

| 项目 | 内容 |
|---|---|
| Komari 面板 | ${KOMARI_ENDPOINT} |
| Token | ${token_masked} |
| 服务状态 | ${status_agent} |
| 远程控制 | 已关闭 Web SSH / 远程命令 |

EOF
  chmod 600 "$KOMARI_REPORT_PATH"
  ln -sf "$KOMARI_REPORT_PATH" "$AKVPS_LATEST_KOMARI_REPORT"
  echo "卡片已保存：$KOMARI_REPORT_PATH"
  cat "$KOMARI_REPORT_PATH"
}

prompt_komari_server() {
  info "Komari 主站信息"
  while true; do
    read -r -p "请输入主站短名，例如 status: " KOMARI_SERVER_NAME
    KOMARI_SERVER_NAME="${KOMARI_SERVER_NAME// /}"
    KOMARI_SERVER_DOMAIN="${KOMARI_SERVER_NAME}.${AKVPS_ROOT_DOMAIN}"
    valid_domain "$KOMARI_SERVER_DOMAIN" && break
    echo "主站短名无法组成合法域名，请重新输入。"
  done
  echo "主站域名：$KOMARI_SERVER_DOMAIN"
}

install_komari_server() {
  info "安装 Komari 主站"
  if port_in_use "$AKVPS_KOMARI_PORT"; then
    die "端口 $AKVPS_KOMARI_PORT 已被占用。" "请先释放端口，再重新运行 akvps。"
  fi
  tmp_file="$(mktemp)"
  curl -fsSL https://raw.githubusercontent.com/komari-monitor/komari/main/install-komari.sh -o "$tmp_file"
  chmod +x "$tmp_file"
  printf "\n" | "$tmp_file"
  rm -f "$tmp_file"
}

generate_komari_server_report() {
  info "生成 Komari 主站卡片"
  KOMARI_SERVER_REPORT_PATH="$AKVPS_REPORT_DIR/$(date +%F-%H%M%S)-komari-server-${KOMARI_SERVER_NAME}.md"
  local status_server access_url password
  status_server="$(systemctl is-active komari 2>/dev/null || echo unknown)"
  access_url="http://${KOMARI_SERVER_DOMAIN}:${AKVPS_KOMARI_PORT}"
  password="$(journalctl -u komari --since "10 minutes ago" 2>/dev/null | grep "admin account created." | tail -n 1 | sed -e 's/.*admin account created.//' | xargs || true)"
  cat > "$KOMARI_SERVER_REPORT_PATH" <<EOF
# akvps Komari 主站卡片

| 项目 | 内容 |
|---|---|
| 主站名称 | ${KOMARI_SERVER_NAME} |
| 主站域名 | ${KOMARI_SERVER_DOMAIN} |
| 访问地址 | ${access_url} |
| 端口 | ${AKVPS_KOMARI_PORT} |
| 用户名 | admin |
| 初始密码 | ${password:-请查看 journalctl -u komari} |
| 服务状态 | ${status_server} |

EOF
  chmod 600 "$KOMARI_SERVER_REPORT_PATH"
  ln -sf "$KOMARI_SERVER_REPORT_PATH" "$AKVPS_LATEST_KOMARI_SERVER_REPORT"
  echo "卡片已保存：$KOMARI_SERVER_REPORT_PATH"
  cat "$KOMARI_SERVER_REPORT_PATH"
}

self_check() {
  echo "akvps 自检"
  echo "版本：$AKVPS_VERSION"
  echo "Bash：${BASH_VERSION:-unknown}"
  echo "配置目录：$AKVPS_DIR"
  echo "报告目录：$AKVPS_REPORT_DIR"
  echo
  echo "命令检查："
  for cmd in bash curl awk sed grep openssl; do
    if command -v "$cmd" >/dev/null 2>&1; then
      echo "- $cmd：存在"
    else
      echo "- $cmd：缺失"
    fi
  done
  echo
  echo "系统检查："
  if [[ -f /etc/os-release ]]; then
    # shellcheck disable=SC1091
    source /etc/os-release
    echo "- 当前系统：${PRETTY_NAME:-unknown}"
  else
    echo "- 当前系统：无法识别"
  fi
}

