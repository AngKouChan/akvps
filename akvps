node_protocols_text() {
  if [[ -n "$NODE_PROTOCOLS" ]]; then
    echo "$NODE_PROTOCOLS"
  elif [[ -L "$AKVPS_LATEST_REPORT" || -f "$AKVPS_LATEST_REPORT" ]]; then
    local raw
    raw="$(grep -m1 '^| 协议准备 |' "$AKVPS_LATEST_REPORT" 2>/dev/null | awk -F'|' '{print $3}' | xargs || true)"
    raw="${raw//VLESS Reality/vless}"
    raw="${raw//Hysteria2 端口跳跃/hy2端口跳跃}"
    raw="${raw//Hysteria2/hy2}"
    raw="${raw//,/ /}"
    echo "${raw:-未记录}"
  else
    echo "未记录"
  fi
}

parse_protocols() {
  local proto="${1:-}" normalized item
  proto="$(lower_text "$proto")"
  normalized="$(printf "%s" "$proto" | sed 's#[/,+;|，、；]# #g')"
  SELECT_VLESS=0
  SELECT_HY2=0
  SELECT_HY2_HOP=0
  for item in $normalized; do
    case "$item" in
      vless)
        SELECT_VLESS=1
        ;;
      hy2|hysteria|hysteria2)
        SELECT_HY2=1
        ;;
      hy2端口跳跃|hy2跳跃|hysteria端口跳跃|hysteria跳跃|hysteria2端口跳跃|hysteria2跳跃|hy2-hop|hy2hop|hysteria-hop|hysteria2-hop|hop)
        SELECT_HY2_HOP=1
        ;;
    esac
  done
}

client_email_prefix() {
  local raw="${NODE_NAME:-node}" safe
  safe="$(printf "%s" "$raw" | sed 's#[/\\[:space:][:cntrl:]]#-#g; s#--*#-#g; s#^-##; s#-$##')"
  printf "%s" "${safe:-node}"
}

client_email_for_kind() {
  local kind="$1" prefix
  prefix="$(client_email_prefix)"
  case "$kind" in
    vless) printf "%s-vless" "$prefix" ;;
    hy2) printf "%s-hy2" "$prefix" ;;
    hy2hop) printf "%s-hy2hop" "$prefix" ;;
    *) printf "%s-%s" "$prefix" "$kind" ;;
  esac
}

tuning_status_text() {
  local bbr qdisc
  bbr="$(sysctl -n net.ipv4.tcp_congestion_control 2>/dev/null || echo unknown)"
  qdisc="$(sysctl -n net.core.default_qdisc 2>/dev/null || echo unknown)"
  if [[ "$bbr" == "bbr" && "$qdisc" == "fq" ]]; then
    echo "BBR+FQ"
  else
    echo "${bbr}/${qdisc}"
  fi
}

