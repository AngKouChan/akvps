probe_menu() {
  while true; do
    echo
    echo "探针部署"
    echo "1. 探针部署"
    echo "2. 主站部署"
    echo "0. 返回"
    read -r -p "请选择: " sub
    case "$sub" in
      1) deploy_komari; return ;;
      2) deploy_komari_server; return ;;
      0) return ;;
    esac
  done
}

placeholder() {
  echo "这个功能后续版本开放。"
}

main_menu() {
  while true; do
    clear 2>/dev/null || true
    echo "Angkou-Vps 轻量版 akvps $AKVPS_VERSION"
    echo
    echo "1. 初始设置"
    echo "2. 面板部署"
    echo "3. 探针部署"
    echo "4. 接入信息"
    echo "5. 修复 / 设置 / 更新 / 卸载"
    echo "0. 退出"
    echo
    read -r -p "请选择: " choice
    case "$choice" in
      1) initial_setup; read -r -p "按回车返回菜单..." _ ;;
      2) deploy_panel; read -r -p "按回车返回菜单..." _ ;;
      3) probe_menu; read -r -p "按回车返回菜单..." _ ;;
      4)
        echo "1. 远端节点接入信息"
        echo "2. 面板卡片"
        echo "3. 探针卡片"
        echo "4. 主站卡片"
        echo "0. 返回"
        read -r -p "请选择: " sub
        [[ "$sub" == "1" ]] && show_latest_report
        [[ "$sub" == "2" ]] && show_latest_panel_report
        [[ "$sub" == "3" ]] && show_latest_komari_report
        [[ "$sub" == "4" ]] && show_latest_komari_server_report
        read -r -p "按回车返回菜单..." _
        ;;
      5)
        echo "1. 恢复 SSH 密码登录"
        echo "0. 返回"
        read -r -p "请选择: " sub
        [[ "$sub" == "1" ]] && restore_ssh_password
        read -r -p "按回车返回菜单..." _
        ;;
      0) exit 0 ;;
    esac
  done
}

case "${1:-menu}" in
  --version|-v|version) version ;;
  check|self-check) self_check ;;
  menu) main_menu ;;
  init|initial-setup) initial_setup ;;
  panel|deploy-panel) deploy_panel ;;
  komari|deploy-komari) deploy_komari ;;
  komari-server|deploy-komari-server) deploy_komari_server ;;
  report) show_latest_report ;;
  panel-report) show_latest_panel_report ;;
  komari-report) show_latest_komari_report ;;
  komari-server-report) show_latest_komari_server_report ;;
  restore-ssh-password) restore_ssh_password ;;
  *) main_menu ;;
esac
