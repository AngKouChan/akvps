  mock_state_cleanup
  mock_state_init
  mock_state_seed_broken_vless
  ensure_master_inbounds >/dev/null
  jq -e '
    (.inbounds | length) == 1
    and (.clients | length) == 1
    and (.inbounds[0].tag == "akvps-aktest-vless")
    and (.inbounds[0].remark == "aktest vless")
    and (.inbounds[0].streamSettings | fromjson | .realitySettings.privateKey) == "old-private"
    and (.inbounds[0].streamSettings | fromjson | .realitySettings.settings.publicKey) == "old-public"
    and (.inbounds[0].streamSettings | fromjson | .realitySettings.shortIds[0]) == "oldsid"
    and (.clients[0].client.email == "aktest-vless")
    and (.clients[0].client.enable == true)
    and (.clients[0].client.subId == "aktest-vless-sub")
    and (.clients[0].client.uuid == "old-uuid")
    and (.clients[0].client.flow == "xtls-rprx-vision")
    and (.clients[0].inboundIds == [1])
  ' "$AKVPS_MOCK_STATE" >/dev/null
  verify_client_links "aktest-vless" vless >/dev/null
  echo "主控一键接入链路自检通过。"
}

initial_setup() {
  node_deploy
