  xui_status="$(service_label x-ui)"
  komari_agent_status="$(service_label komari-agent)"
  komari_server_status="$(service_label komari)"
  role_master="$([[ "$ROLE_MASTER_PANEL" == "1" ]] && echo yes || true)"
  role_node="$([[ "$ROLE_NODE" == "1" ]] && echo yes || true)"
  role_agent="$([[ "$ROLE_KOMARI_AGENT" == "1" ]] && echo yes || true)"
  role_komari_server="$([[ "$ROLE_KOMARI_SERVER" == "1" ]] && echo yes || true)"
  roles=""
