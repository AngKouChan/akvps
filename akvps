setup_ssh() {
  info "配置 SSH 密钥登录"
  install -d -m 700 /root/.ssh
  touch /root/.ssh/authorized_keys
  chmod 600 /root/.ssh/authorized_keys
  grep -qxF "$AKVPS_TERMIUS_PUBKEY" /root/.ssh/authorized_keys || printf "%s\n" "$AKVPS_TERMIUS_PUBKEY" >> /root/.ssh/authorized_keys

  install -d -m 755 /etc/ssh/sshd_config.d
  [[ -f /etc/ssh/sshd_config ]] && cp -a /etc/ssh/sshd_config "/etc/ssh/sshd_config.bak.akvps.$(date +%F-%H%M%S)" || true
  cat > "$AKVPS_SSHD_CONF" <<'EOF'
PubkeyAuthentication yes
PasswordAuthentication no
KbdInteractiveAuthentication no
PermitRootLogin prohibit-password
EOF
  if ! sshd -t; then
    rm -f "$AKVPS_SSHD_CONF"
    die "SSH 配置检查失败，已回滚。" "请检查系统 SSH 配置后重试。"
  fi
  systemctl reload ssh 2>/dev/null || systemctl reload sshd 2>/dev/null || true
}

restore_ssh_password() {
  need_root
  rm -f "$AKVPS_SSHD_CONF"
  systemctl reload ssh 2>/dev/null || systemctl reload sshd 2>/dev/null || true
  echo "已恢复 SSH 密码登录配置。"
}

