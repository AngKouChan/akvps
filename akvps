protocol_text() {
  local out=()
  [[ "$SELECT_VLESS" -eq 1 ]] && out+=("VLESS Reality")
  [[ "$SELECT_HY2" -eq 1 ]] && out+=("Hysteria2")
  [[ "$SELECT_HY2_HOP" -eq 1 ]] && out+=("Hysteria2 端口跳跃")
  (IFS=", "; echo "${out[*]}")
}

protocol_short_text() {
  local out=()
  [[ "$SELECT_VLESS" -eq 1 ]] && out+=("vless")
  [[ "$SELECT_HY2" -eq 1 ]] && out+=("hy2")
  [[ "$SELECT_HY2_HOP" -eq 1 ]] && out+=("hy2端口跳跃")
  if ((${#out[@]} == 0)); then
    echo ""
  else
    local joined="${out[0]}" i
    for ((i = 1; i < ${#out[@]}; i++)); do
      joined="$joined / ${out[$i]}"
    done
    echo "$joined"
  fi
}

planned_inbound_kinds() {
  local proto="${1:-}" out=()
  parse_protocols "$proto"
  [[ "$SELECT_VLESS" -eq 1 ]] && out+=("vless")
  [[ "$SELECT_HY2" -eq 1 ]] && out+=("hy2")
  [[ "$SELECT_HY2_HOP" -eq 1 ]] && out+=("hy2hop")
  if ((${#out[@]} == 0)); then
    echo ""
  else
    local joined="${out[0]}" i
    for ((i = 1; i < ${#out[@]}; i++)); do
      joined="$joined ${out[$i]}"
    done
    echo "$joined"
  fi
}

