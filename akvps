placeholder() {
  echo "这个功能后续版本开放。"
}

main_menu() {
  while true; do
    clear 2>/dev/null || true
    echo "Angkou-Vps 轻量版 akvps $AKVPS_VERSION"
    echo
    show_dashboard
    echo "1. 基础设置"
    echo "2. 本机部署"
    echo "3. 日常维护"
    echo "4. 更新 / 卸载"
    echo "q. 退出"
    echo
    read -r -p "请选择: " choice
    case "$choice" in
      1) basic_settings_menu ;;
      2) local_deploy_menu ;;
      3) maintenance_menu ;;
      4) updates_menu ;;
      q|Q) exit 0 ;;
    esac
  done
}

case "${1:-menu}" in
  --version|-v|version) version ;;
  check|self-check) self_check ;;
  menu) main_menu ;;
  init|initial-setup|node|node-deploy) node_deploy ;;
  panel|deploy-panel|local-deploy) local_deploy_menu ;;
  komari|deploy-komari) deploy_komari ;;
  komari-server|deploy-komari-server) deploy_komari_server ;;
  report) show_latest_report ;;
  panel-report) show_latest_panel_report ;;
  komari-report) show_latest_komari_report ;;
  komari-server-report) show_latest_komari_server_report ;;
  settings|info-settings|basic-settings) basic_settings_menu ;;
  connect-master|connect-node) connect_node_to_master ;;
  verify-master|verify-node) verify_master_connection ;;
  verify-komari) verify_komari_agent ;;
  update-akvps) update_akvps ;;
  uninstall-akvps) uninstall_akvps ;;
  restore-ssh-password) restore_ssh_password ;;
  *) main_menu ;;
esac
