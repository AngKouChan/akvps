cf_zone_id() {
  require_tools_for_json
  cloudflare_api GET "zones?name=$AKVPS_ROOT_DOMAIN" | jq -r '.result[0].id // empty'
}

upsert_dns_record() {
  local zone_id="$1" type="$2" name="$3" content="$4"
  [[ -n "$content" ]] || return 0
  local record_id payload
  record_id="$(cloudflare_api GET "zones/$zone_id/dns_records?type=$type&name=$name" | jq -r '.result[0].id // empty')"
  payload="$(jq -n --arg type "$type" --arg name "$name" --arg content "$content" '{type:$type,name:$name,content:$content,ttl:1,proxied:false}')"
  if [[ -n "$record_id" ]]; then
    cloudflare_api PUT "zones/$zone_id/dns_records/$record_id" "$payload" >/dev/null
  else
    cloudflare_api POST "zones/$zone_id/dns_records" "$payload" >/dev/null
  fi
}

setup_dns() {
  info "配置 Cloudflare DNS"
  local zone_id
  zone_id="$(cf_zone_id)"
  [[ -n "$zone_id" ]] || die "找不到 Cloudflare Zone：$AKVPS_ROOT_DOMAIN" "请检查 Token 权限是否包含 Zone Read 和 DNS Edit。"
  upsert_dns_record "$zone_id" "A" "$NODE_DOMAIN" "$PUBLIC_IPV4"
  [[ -n "$PUBLIC_IPV6" ]] && upsert_dns_record "$zone_id" "AAAA" "$NODE_DOMAIN" "$PUBLIC_IPV6"
  echo "DNS 已更新：$NODE_DOMAIN"
}

setup_dns_for_domain() {
  local domain="$1"
  info "配置 Cloudflare DNS"
  local zone_id
  zone_id="$(cf_zone_id)"
  [[ -n "$zone_id" ]] || die "找不到 Cloudflare Zone：$AKVPS_ROOT_DOMAIN" "请检查 Token 权限是否包含 Zone Read 和 DNS Edit。"
  upsert_dns_record "$zone_id" "A" "$domain" "$PUBLIC_IPV4"
  [[ -n "$PUBLIC_IPV6" ]] && upsert_dns_record "$zone_id" "AAAA" "$domain" "$PUBLIC_IPV6"
  echo "DNS 已更新：$domain"
}

wait_dns() {
  info "等待 DNS 生效"
  wait_dns_for_domain "$NODE_DOMAIN"
}

resolve_ipv4_public() {
  local domain="$1"
  curl -fsS --max-time 8 "https://cloudflare-dns.com/dns-query?name=${domain}&type=A" \
    -H "accept: application/dns-json" 2>/dev/null \
    | jq -r '.Answer[]? | select(.type == 1) | .data' \
    | sort -u | tr '\n' ' ' || true
}

wait_dns_for_domain() {
  local domain="$1"
  local i resolved=""
  for i in $(seq 1 30); do
    resolved="$(resolve_ipv4_public "$domain")"
    [[ -n "$resolved" ]] || resolved="$(getent ahostsv4 "$domain" 2>/dev/null | awk '{print $1}' | sort -u | tr '\n' ' ' || true)"
    if [[ " $resolved " == *" $PUBLIC_IPV4 "* ]]; then
      echo "DNS 已生效：$domain -> $PUBLIC_IPV4"
      return 0
    fi
    echo "等待 DNS 生效中... $i/30"
    sleep 10
  done
  die "DNS 暂未解析到当前 VPS IPv4。" "请稍后重新运行 akvps，或检查 Cloudflare DNS。"
}

random_string() {
  openssl rand -hex 64 | cut -c "1-${1:-18}"
}

json_success() {
  jq -e '.success == true' >/dev/null 2>&1
}

api_base_from_panel_url() {
  local url="${PANEL_URL%/}"
  printf "%s/panel/api" "$url"
}

url_origin_from_url() {
  local url="$1" origin
  origin="${url#*://}"
  origin="${origin%%/*}"
  printf "%s://%s" "${url%%://*}" "$origin"
}

api_base_candidates() {
  local with_path origin
  with_path="$(api_base_from_panel_url)"
  origin="$(url_origin_from_url "$PANEL_URL")/panel/api"
  echo "$with_path"
  [[ "$origin" != "$with_path" ]] && echo "$origin"
}

node_base_path_from_url() {
  local url="$1" path
  path="/$(printf "%s" "$url" | sed -E 's|^[a-zA-Z]+://[^/]+/?||')"
  [[ "$path" == "/" ]] || path="${path%/}/"
  printf "%s" "$path"
}

url_host_from_url() {
  local url="$1" host
  host="${url#*://}"
  host="${host%%/*}"
  host="${host%%:*}"
  printf "%s" "$host"
}

is_local_master_panel() {
  [[ -x "$XUI_BIN" ]] \
    && [[ -n "$PANEL_URL" && -n "$PANEL_API_TOKEN" ]] \
    && { [[ -n "$MASTER_IPV4" && -n "$PUBLIC_IPV4" && "$MASTER_IPV4" == "$PUBLIC_IPV4" ]] \
      || [[ -n "$MASTER_IPV6" && -n "$PUBLIC_IPV6" && "$MASTER_IPV6" == "$PUBLIC_IPV6" ]]; }
}

xui_api() {
  local method="$1" path="$2" data="${3:-}"
  local api_base response body status tried="" best_status="" best_body=""
  while IFS= read -r api_base; do
    tried="${tried}- ${api_base}${path}"$'\n'
    if [[ -n "$data" ]]; then
      response="$(curl -ksS -X "$method" "${api_base}${path}" \
        -H "Authorization: Bearer $PANEL_API_TOKEN" \
        -H "Content-Type: application/json" \
        -H "X-Requested-With: XMLHttpRequest" \
        --data "$data" \
        -w $'\n%{http_code}' 2>/dev/null || true)"
    else
      response="$(curl -ksS -X "$method" "${api_base}${path}" \
        -H "Authorization: Bearer $PANEL_API_TOKEN" \
        -H "Content-Type: application/json" \
        -H "X-Requested-With: XMLHttpRequest" \
        -w $'\n%{http_code}' 2>/dev/null || true)"
    fi
    status="$(printf "%s" "$response" | tail -n 1)"
    body="$(printf "%s" "$response" | sed '$d')"
    if [[ -z "$best_status" || "$best_status" == "404" || "$status" == "401" ]]; then
      best_status="$status"
      best_body="$body"
    fi
    if [[ "$status" =~ ^2[0-9][0-9]$ ]]; then
      printf "%s" "$body"
      return 0
    fi
  done < <(api_base_candidates)
  echo "主控 API 返回 HTTP ${best_status:-unknown}。" >&2
  case "$best_status" in
    401|403)
      echo "判断：主控 API Token 不正确、已失效，或主控面板没有启用这个 Token。" >&2
      ;;
    404)
      echo "判断：主控 API 地址可能不对，或主控面板基础路径不对。" >&2
      ;;
    000|"")
      echo "判断：无法连到主控面板，请检查主控 IP、端口和防火墙。" >&2
      ;;
  esac
  [[ -n "$best_body" ]] && echo "主控返回：$(printf "%s" "$best_body" | tr '\n' ' ' | head -c 160)" >&2
  echo "已尝试地址：" >&2
  printf "%s" "$tried" >&2
  return 1
}

build_node_payload() {
  local base_path address
  base_path="$(node_base_path_from_url "$NODE_XUI_URL")"
  address="$(url_host_from_url "$NODE_XUI_URL")"
  [[ -n "$address" ]] || address="$NODE_DOMAIN"
  jq -n \
    --arg name "$NODE_NAME" \
    --arg address "$address" \
    --arg basePath "$base_path" \
    --arg apiToken "$NODE_XUI_API_TOKEN" \
    --argjson port "$AKVPS_XUI_PORT" \
    '{
      name: $name,
      remark: $name,
      scheme: "https",
      address: $address,
      port: $port,
      basePath: $basePath,
      apiToken: $apiToken,
      enable: true,
      allowPrivateAddress: false,
      tlsVerifyMode: "verify",
      pinnedCertSha256: "",
      inboundSyncMode: "all",
      inboundTags: [],
      outboundTag: ""
    }'
}

connect_node_to_master() {
  need_root
  ensure_dirs
  load_envs
  require_tools_for_json
  [[ -n "$PANEL_URL" ]] || die "缺少主控面板地址。" "请先到 1. 基础设置 -> 3. 主控信息 导入 PANEL_URL。"
  [[ -n "$PANEL_API_TOKEN" ]] || die "缺少主控 API Token。" "请先到 1. 基础设置 -> 3. 主控信息 导入 PANEL_API_TOKEN。"
  [[ -n "$NODE_NAME" && -n "$NODE_DOMAIN" && -n "$NODE_XUI_API_TOKEN" ]] || die "缺少当前节点信息。" "请先运行 2. 本机部署 -> 1. 代理节点。"

  info "测试节点连通"
  local payload response status msg
  payload="$(build_node_payload)"
  response="$(xui_api POST "/nodes/test" "$payload")" || die "无法连接主控面板 API。" "如果上面显示 HTTP 401/403，请重新导入主控机卡片里的完整 PANEL_API_TOKEN。"
  status="$(printf "%s" "$response" | jq -r '.obj.status // empty')"
  msg="$(printf "%s" "$response" | jq -r '.msg // empty')"
  [[ "$status" == "online" ]] || die "主控未能连上这个节点。" "请检查节点域名、11123 端口、节点 API Token。主控返回：${msg:-unknown}"

  info "接入主控面板"
  local existing_id action
  existing_id="$(xui_api GET "/nodes/list" | jq -r --arg name "$NODE_NAME" '.obj[]? | select(.name == $name) | .id' | head -n1)" || existing_id=""
  if [[ -n "$existing_id" ]]; then
    response="$(xui_api POST "/nodes/update/${existing_id}" "$payload")" || die "主控更新节点失败。" "请重新导入主控机卡片里的完整 PANEL_API_TOKEN。"
    action="已更新"
  else
    response="$(xui_api POST "/nodes/add" "$payload")" || die "主控添加节点失败。" "请重新导入主控机卡片里的完整 PANEL_API_TOKEN。"
    action="已添加"
  fi
  if printf "%s" "$response" | json_success; then
    echo "${action}主控节点：$NODE_NAME"
  else
    msg="$(printf "%s" "$response" | jq -r '.msg // empty')"
    die "主控接入节点失败。" "主控返回：${msg:-unknown}"
  fi

  info "验证主控接入"
  existing_id="$(xui_api GET "/nodes/list" | jq -r --arg name "$NODE_NAME" '.obj[]? | select(.name == $name) | .id' | head -n1)" || existing_id=""
  [[ -n "$existing_id" ]] || die "主控列表里没有找到这个节点。" "请稍后在主控面板节点列表确认，或重新运行节点部署。"
  echo "验证通过：主控已存在节点 $NODE_NAME"
}

verify_master_connection() {
  need_root
  ensure_dirs
  load_envs
  require_tools_for_json
  [[ -n "$PANEL_URL" && -n "$PANEL_API_TOKEN" ]] || die "缺少主控信息。" "请先到 1. 基础设置 -> 3. 主控信息 导入。"
  [[ -n "$NODE_NAME" ]] || die "缺少节点名称。" "请先部署代理节点。"
