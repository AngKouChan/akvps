install_komari_server() {
  info "安装 Komari 主站"
  KOMARI_SERVER_REUSED=0
  if port_in_use "$AKVPS_KOMARI_PORT"; then
    if systemctl is-active --quiet komari 2>/dev/null; then
      echo "检测到已安装 Komari 主站。"
      echo "1. 复用现有主站"
      echo "2. 重装主站（会删除旧 Komari 数据，并重新生成账号密码）"
      echo "0. 取消"
      read -r -p "请选择: " choice
      case "$choice" in
        1)
          KOMARI_SERVER_REUSED=1
          return 0
          ;;
        2)
          read -r -p "确认重装？输入 YES 继续: " confirm
          [[ "$confirm" == "YES" ]] || die "已取消重装。" "需要时重新运行探针主站部署。"
          systemctl stop komari 2>/dev/null || true
          systemctl disable komari 2>/dev/null || true
          rm -f "$KOMARI_SERVICE"
          systemctl daemon-reload 2>/dev/null || true
          rm -rf "$KOMARI_DIR"
          ;;
        0)
          die "已取消。" "需要时重新运行探针主站部署。"
          ;;
        *)
          die "选择无效。" "请选择 1、2 或 0。"
          ;;
      esac
    else
      die "端口 $AKVPS_KOMARI_PORT 已被占用。" "请先释放端口，再重新运行 akvps。"
    fi
  fi
  tmp_file="$(mktemp)"
  curl -fsSL https://raw.githubusercontent.com/komari-monitor/komari/main/install-komari.sh -o "$tmp_file"
  chmod +x "$tmp_file"
  printf "1\n\n" | "$tmp_file"
  rm -f "$tmp_file"
  systemctl is-active --quiet komari 2>/dev/null || die "Komari 主站安装后未运行。" "请查看 journalctl -u komari -n 80。"
}

setup_komari_caddy() {
  info "配置 Komari HTTPS"
  local i
  mkdir -p /etc/caddy
  cat > /etc/caddy/Caddyfile <<EOF
${KOMARI_SERVER_DOMAIN} {
  reverse_proxy 127.0.0.1:${AKVPS_KOMARI_PORT}
}
EOF
  caddy validate --config /etc/caddy/Caddyfile >/dev/null
  systemctl enable caddy >/dev/null 2>&1 || true
  systemctl restart caddy
  for i in $(seq 1 24); do
    if curl -fsS --max-time 10 "https://${KOMARI_SERVER_DOMAIN}" >/dev/null 2>&1; then
      echo "Komari HTTPS 已生效：https://${KOMARI_SERVER_DOMAIN}"
      return 0
    fi
    echo "等待 HTTPS 生效中... $i/24"
    sleep 5
  done
  die "Komari HTTPS 暂未成功。" "请稍后访问 https://${KOMARI_SERVER_DOMAIN}，或查看 journalctl -u caddy -n 80。"
}

generate_komari_server_report() {
  info "生成 Komari 主站卡片"
  KOMARI_SERVER_REPORT_PATH="$AKVPS_REPORT_DIR/$(date +%F-%H%M%S)-komari-server-${KOMARI_SERVER_NAME}.md"
  local status_server access_url password password_text
  status_server="$(systemctl is-active komari 2>/dev/null || echo unknown)"
  [[ "$status_server" == "active" ]] || die "Komari 主站未正常运行。" "请查看 journalctl -u komari -n 80。"
  access_url="https://${KOMARI_SERVER_DOMAIN}"
  save_config_var "KOMARI_SERVER_DOMAIN" "$KOMARI_SERVER_DOMAIN"
  save_config_var "KOMARI_ENDPOINT" "$access_url"
  password="$(journalctl -u komari --since "10 minutes ago" 2>/dev/null \
    | grep "admin account created." \
    | tail -n 1 \
    | sed -E 's/.*Password: ([^ ,)]+).*/\1/' \
    | xargs || true)"
  if [[ "$KOMARI_SERVER_REUSED" -eq 1 ]]; then
    password_text="已有主站，请使用现有账号密码"
  else
    password_text="${password:-请查看 journalctl -u komari}"
  fi
  cat > "$KOMARI_SERVER_REPORT_PATH" <<EOF
# akvps Komari 主站卡片

| 项目 | 内容 |
|---|---|
| 主站名称 | ${KOMARI_SERVER_NAME} |
| 主站域名 | ${KOMARI_SERVER_DOMAIN} |
| 访问地址 | ${access_url} |
| 端口 | ${AKVPS_KOMARI_PORT} |
| 用户名 | admin |
| 初始密码 | ${password_text} |
| 服务状态 | ${status_server} |

EOF
  chmod 600 "$KOMARI_SERVER_REPORT_PATH"
  ln -sf "$KOMARI_SERVER_REPORT_PATH" "$AKVPS_LATEST_KOMARI_SERVER_REPORT"
  echo "卡片已保存：$KOMARI_SERVER_REPORT_PATH"
  cat "$KOMARI_SERVER_REPORT_PATH"
}

self_check() {
  echo "akvps 自检"
  echo "版本：$AKVPS_VERSION"
  echo "Bash：${BASH_VERSION:-unknown}"
  echo "配置目录：$AKVPS_DIR"
  echo "报告目录：$AKVPS_REPORT_DIR"
  echo
  echo "命令检查："
  for cmd in bash curl awk sed grep openssl; do
    if command -v "$cmd" >/dev/null 2>&1; then
      echo "- $cmd：存在"
    else
      echo "- $cmd：缺失"
    fi
  done
  echo
  echo "系统检查："
  if [[ -f /etc/os-release ]]; then
    # shellcheck disable=SC1091
    source /etc/os-release
    echo "- 当前系统：${PRETTY_NAME:-unknown}"
  else
    echo "- 当前系统：无法识别"
  fi
}

