status_label() {
  if [[ -n "$1" ]]; then
    color_text green "☑"
  else
    color_text yellow "☐"
  fi
}

service_label() {
  local service="$1"
  if systemctl is-active --quiet "$service" 2>/dev/null; then
    color_text green "☑"
  else
    color_text yellow "☐"
  fi
}

append_role() {
  local current="$1" color="$2" label="$3"
  if [[ -n "$current" ]]; then
    printf "%s %s" "$current" "$(color_text "$color" "$label")"
  else
    color_text "$color" "$label"
  fi
}

