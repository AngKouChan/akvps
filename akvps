xray_bin() {
  local candidate found
  for candidate in \
    "$(command -v xray 2>/dev/null || true)" \
    /usr/local/bin/xray \
    /usr/bin/xray \
    /usr/local/x-ui/bin/xray \
    /usr/local/x-ui/bin/xray-linux-amd64 \
    /usr/local/x-ui/bin/xray-linux-arm64 \
    /usr/local/x-ui/xray \
    /opt/xray/xray; do
    if [[ -n "$candidate" && -x "$candidate" ]]; then
      printf "%s" "$candidate"
      return 0
    fi
  done

  if [[ -d /usr/local/x-ui ]]; then
    found="$(find /usr/local/x-ui -type f \( -name 'xray' -o -name 'xray-*' -o -name 'xray-linux-*' \) -perm -111 2>/dev/null | sort | head -n1 || true)"
    if [[ -n "$found" ]]; then
      printf "%s" "$found"
      return 0
    fi
  fi

  return 0
}

xray_release_asset() {
  case "$(uname -m 2>/dev/null || true)" in
    x86_64|amd64) printf "Xray-linux-64.zip" ;;
    aarch64|arm64) printf "Xray-linux-arm64-v8a.zip" ;;
    armv7l|armv7*) printf "Xray-linux-arm32-v7a.zip" ;;
    *) return 1 ;;
  esac
}

download_temp_xray_bin() {
  local asset tmp_dir zip_file bin_file
  asset="$(xray_release_asset)" || return 0
  command -v curl >/dev/null 2>&1 || return 0
  command -v unzip >/dev/null 2>&1 || return 0
  tmp_dir="$(mktemp -d /tmp/akvps-xray.XXXXXX 2>/dev/null || mktemp -d)" || return 0
  zip_file="$tmp_dir/xray.zip"
  bin_file="$tmp_dir/xray"
  if curl -fsSL --connect-timeout 10 --max-time 90 \
    "https://github.com/XTLS/Xray-core/releases/latest/download/${asset}" \
    -o "$zip_file" >/dev/null 2>&1 \
    && unzip -q "$zip_file" -d "$tmp_dir" >/dev/null 2>&1 \
    && [[ -f "$bin_file" ]]; then
    chmod +x "$bin_file" 2>/dev/null || true
    [[ -x "$bin_file" ]] && printf "%s" "$bin_file" && return 0
  fi
  rm -rf "$tmp_dir" 2>/dev/null || true
  return 0
}

run_xray_x25519() {
  local bin="$1" out private public
  [[ -n "$bin" && -x "$bin" ]] || return 1
  out="$("$bin" x25519 2>/dev/null || true)"
  private="$(printf "%s" "$out" | awk -F': *' 'tolower($1) ~ /private[[:space:]]*key/ || tolower($1) == "privatekey" {print $2; exit}')"
  public="$(printf "%s" "$out" | awk -F': *' 'tolower($1) ~ /public[[:space:]]*key/ || tolower($1) ~ /publickey/ {print $2; exit}')"
  [[ -n "$private" && -n "$public" ]] || return 1
  printf "%s|%s" "$private" "$public"
}

generate_reality_keys() {
  local bin pair private public tmp_dir=""
  bin="$(xray_bin)"
  pair="$(run_xray_x25519 "$bin" 2>/dev/null || true)"
  if [[ -z "$pair" ]]; then
    bin="$(download_temp_xray_bin)"
    [[ "$bin" == /tmp/akvps-xray.*/* ]] && tmp_dir="${bin%/*}"
    pair="$(run_xray_x25519 "$bin" 2>/dev/null || true)"
  fi
  private="${pair%%|*}"
  public="${pair#*|}"
  if [[ -z "$private" || -z "$public" ]]; then
    private=""
    public=""
  fi
  [[ -n "$tmp_dir" && -d "$tmp_dir" ]] && rm -rf "$tmp_dir" 2>/dev/null || true
  printf "%s|%s" "$private" "$public"
}

